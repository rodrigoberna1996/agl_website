---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/HeroSection.astro';
import AboutSection from '@components/AboutSection.astro';
import HowItWorksSection from '@components/HowItWorksSection.astro';
import PortfolioSection from '@components/PortfolioSection.astro';
import TestimonialsSection from '@components/TestimonialsSection.astro';
import FAQ from '@components/FAQ.astro';
import heroVideoPoster from '/src/assets/images/catalog/agl_43.jpeg';
---

<BaseLayout preloadLcpImage={heroVideoPoster.src}>
  <PortfolioSection hideSectionHeading />
  <HeroSection />
  <TestimonialsSection />
  <HowItWorksSection />
  <AboutSection />
  <FAQ />
</BaseLayout>

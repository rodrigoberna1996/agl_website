---
import { CONTACT_LOCATIONS, SITE, toTelHref } from "@consts";

const currentYear = new Date().getFullYear();

const phonesCdmx =
  CONTACT_LOCATIONS.find((l) => l.id === "cdmx")?.phones ?? [];
const phonesMorelos =
  CONTACT_LOCATIONS.find((l) => l.id === "morelos")?.phones ?? [];
---

<footer class="main-footer">
    <div class="section-container footer-grid">
        <div class="footer-col">
            <h2 class="footer-heading">Marcas que distribuimos</h2>
            <ul class="footer-list">
                <li>TotalEnergies®</li>
                <li>ELF®</li>
            </ul>
        </div>

        <div class="footer-col">
            <h2 class="footer-heading">Estados de cobertura</h2>
            <ul class="footer-list">
                <li>CDMX</li>
                <li>Estado de México</li>
                <li>Morelos</li>
                <li>Oaxaca</li>
            </ul>
        </div>

        <div class="footer-col">
            <h2 class="footer-heading">Segmentos y soluciones</h2>
            <ul class="footer-list">
                <li>Lubricantes Industriales</li>
                <li>Lubricantes para Motocicletas</li>
                <li>Lubricantes automotrices</li>
                <li>
                    Lubricantes para Motor a Diésel y servicio pesado
                </li>
                <li>Lubricantes para Maquinaria de Construcción</li>
            </ul>
        </div>

        <div class="footer-col">
            <h2 class="footer-heading">Contacto</h2>
            <div class="footer-contact-group">
                <p class="footer-contact-region">CDMX</p>
                <ul class="footer-list footer-list--contact">
                    {
                        phonesCdmx.map((phone) => (
                            <li>
                                <a
                                    href={toTelHref(phone)}
                                    class="footer-link"
                                >
                                    {phone}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>
            <div class="footer-contact-group">
                <p class="footer-contact-region">Cuernavaca</p>
                <ul class="footer-list footer-list--contact">
                    {
                        phonesMorelos.map((phone) => (
                            <li>
                                <a
                                    href={toTelHref(phone)}
                                    class="footer-link"
                                >
                                    {phone}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="section-container footer-bottom-inner">
            <p class="footer-copyright">
                &copy; {SITE.COMPANY_NAME} {currentYear}.
            </p>
        </div>
    </div>
</footer>

<style>
    .main-footer {
        --footer-bg: #10264f;
        --footer-heading-color: #ffffff;
        --footer-text: rgba(255, 255, 255, 0.72);
        --footer-text-muted: rgba(255, 255, 255, 0.55);

        background: var(--footer-bg);
        padding-block: var(--px-80) 0;
        padding-inline: var(--px-64);
        color: var(--footer-text);
        font-size: var(--text-sm);
    }

    .footer-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: var(--px-40) var(--px-32);
        padding-bottom: var(--px-80);
    }

    .footer-heading {
        margin: 0 0 var(--px-16);
        font-size: var(--text-base);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.35;
        color: var(--footer-heading-color);
        border-left: 3px solid var(--color-brand-red);
        padding-left: var(--px-12);
    }

    .footer-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--px-10);
        line-height: 1.5;
        color: var(--footer-text);
    }

    .footer-list--contact {
        gap: var(--px-8);
    }

    .footer-contact-group {
        margin-bottom: var(--px-24);
    }

    .footer-contact-group:last-child {
        margin-bottom: 0;
    }

    .footer-contact-region {
        margin: 0 0 var(--px-10);
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--footer-text);
    }

    .footer-link {
        color: inherit;
        text-decoration: none;
        transition: color var(--transition-short);
    }

    .footer-link:active {
        color: var(--footer-heading-color);
    }

    @media (hover: hover) and (pointer: fine) {
        .footer-link:hover {
            color: var(--footer-heading-color);
        }
    }

    .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        padding-block: var(--px-28);
    }

    .footer-bottom-inner {
        display: flex;
        align-items: center;
    }

    .footer-copyright {
        margin: 0;
        font-size: var(--text-xs);
        color: var(--footer-text-muted);
    }

    @media screen and (max-width: 64rem) {
        .main-footer {
            padding-inline: var(--px-28);
            padding-block-start: var(--px-64);
        }

        .footer-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            padding-bottom: var(--px-64);
            gap: var(--px-36) var(--px-28);
        }
    }

    @media screen and (max-width: 40rem) {
        .footer-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

---
const serviceSteps = [
    {
        eyebrow: "01",
        title: "Identificamos la aplicación",
        description:
            "Motor, transmisión, hidráulico, engranaje o grasa: partimos del equipo y las condiciones reales de trabajo.",
    },
    {
        eyebrow: "02",
        title: "Recomendamos el producto correcto",
        description:
            "Aterrizamos viscosidad, especificación, marca y presentación para reducir dudas en compra y mantenimiento.",
    },
    {
        eyebrow: "03",
        title: "Entregamos y damos seguimiento",
        description:
            "Atendemos pedidos en zonas de cobertura con soporte comercial para talleres, flotillas e industria.",
    },
];
---

<section id="how-it-works" class="support" aria-labelledby="support-heading">
    <div class="section-container support-container">
        <div class="support-copy">
            <span class="section-tag">Asesoría especializada</span>
            <h2 id="support-heading" class="section-title">
                El valor de AGL está en ayudar a elegir bien.
            </h2>
            <p class="support-lead">
                TotalEnergies comunica tecnología y confianza. En AGL lo llevamos
                al terreno práctico: disponibilidad, recomendación técnica y
                atención cercana.
            </p>
            <a href="/contact" class="btn btn--primary">Solicitar asesoría</a>
        </div>

        <div class="support-steps">
            {
                serviceSteps.map((step) => (
                    <article class="support-step">
                        <span class="support-step__eyebrow">{step.eyebrow}</span>
                        <div>
                            <h3 class="support-step__title">{step.title}</h3>
                            <p class="support-step__description">{step.description}</p>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    .support {
        background: var(--color-brand-navy);
        color: var(--color-white);
    }

    .support :global(.section-tag),
    .support :global(.section-title) {
        color: var(--color-white);
    }

    .support-container {
        display: grid;
        grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
        gap: var(--px-64);
        align-items: start;
    }

    .support-copy {
        max-width: 42rem;
    }

    .support-lead {
        margin-top: calc(var(--px-48) * -1);
        margin-bottom: var(--px-40);
        color: rgba(255, 255, 255, 0.78);
        font-size: var(--text-xl);
    }

    .support-steps {
        display: grid;
        gap: var(--px-20);
    }

    .support-step {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: var(--px-24);
        padding: var(--px-28);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: var(--px-16);
        background: rgba(255, 255, 255, 0.06);
    }

    .support-step__eyebrow {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: var(--px-48);
        height: var(--px-48);
        border-radius: var(--px-8);
        background: var(--color-brand-red);
        color: var(--color-white);
        font-weight: 800;
    }

    .support-step__title {
        margin: 0 0 var(--px-8);
        font-size: var(--text-xl);
        font-weight: 800;
        line-height: 1.2;
    }

    .support-step__description {
        margin: 0;
        color: rgba(255, 255, 255, 0.78);
    }

    @media screen and (max-width: 64rem) {
        .support-container {
            grid-template-columns: 1fr;
            gap: var(--px-40);
        }

        .support-lead {
            margin-top: 0;
        }
    }

    @media screen and (max-width: 42.188rem) {
        .support-step {
            grid-template-columns: 1fr;
        }
    }
</style>

<header id="header" class="header">
    <div class="mobile-overlay"></div>
    <nav
        class="section-container nav-container"
        role="navigation"
        aria-label="Main navigation"
    >
        <div class="logo-container">
            <a href="/" class="logo" aria-label="AGL Legaspi home">
                <img
                    src="/branding/LOGO-AGL.png"
                    alt=""
                    width="1024"
                    height="336"
                    class="logo-img logo-img--full"
                    decoding="async"
                />
                <img
                    src="/branding/FLAMA.png"
                    alt=""
                    width="804"
                    height="392"
                    class="logo-img logo-img--mark"
                    decoding="async"
                />
            </a>
        </div>

        <div class="nav-content">
            <ul class="nav-menu">
                <li class="nav-item">
                    <a href="/" class="nav-link">Inicio</a>
                </li>
                <li class="nav-item">
                    <a href="/about" class="nav-link">Quiénes Somos</a>
                </li>
                <li class="nav-item">
                    <a href="/products" class="nav-link">Productos</a>
                </li>
                <li class="nav-item">
                    <a
                        href="/portfolio"
                        class="nav-link"
                        data-astro-prefetch="false"
                        data-astro-reload
                    >Blog</a>
                </li>
                <li class="nav-item">
                    <a href="/contact" class="nav-link">Contacto</a>
                </li>
            </ul>

            <a
                href="/products"
                class="nav-link header-search-cta header-search-cta--mobile"
                aria-label="Ver productos"
            >
                <svg
                    class="header-search-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </svg>
            </a>
        </div>

        <a
            href="/products"
            class="header-search-cta header-search-cta--desktop"
            aria-label="Ver productos"
        >
            <svg
                class="header-search-icon"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
            </svg>
        </a>

        <button
            class="hamburger"
            aria-label="Toggle menu"
            aria-expanded="false"
        >
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
        </button>
    </nav>
</header>

<div id="trigger" class="trigger"></div>

<style>
    .header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: var(--h-menu-bar);
        display: flex;
        padding-inline: var(--px-32);
        z-index: var(--z-max);
        transition: all var(--transition-short);
    }

    .nav-container {
        position: relative;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: var(--text-base);
        font-weight: 500;
    }

    .logo {
        display: flex;
        align-items: center;
        line-height: 0;
        color: inherit;
    }

    .logo-img {
        height: auto;
        width: auto;
        max-height: calc(var(--h-menu-bar) - 1.25rem);
        max-width: min(14rem, 42vw);
        object-fit: contain;
    }

    .logo-img--mark {
        display: none;
        max-width: 3.25rem;
        max-height: calc(var(--h-menu-bar) - 1rem);
    }

    .scrolled .logo-img {
        max-height: calc(var(--h-menu-bar-scrolled) - 0.875rem);
    }

    .scrolled .logo-img--mark {
        max-height: calc(var(--h-menu-bar-scrolled) - 0.75rem);
    }

    .hamburger {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: var(--px-28);
        height: var(--px-18);
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: var(--z-max);
    }

    .hamburger-line {
        display: block;
        width: 100%;
        height: var(--px-2);
        background-color: currentColor;
        transition: transform var(--transition-medium);
    }

    .nav-menu {
        display: flex;
    }

    .nav-item {
        margin-inline: var(--px-16);
    }

    .nav-link {
        display: flex;
        opacity: 0.65;
        transition: all var(--transition-short);
    }

    .nav-link:active {
        opacity: 1;
        transform: scale(0.98);
    }

    .header-search-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: inherit;
        line-height: 0;
        opacity: 0.65;
        transition: opacity var(--transition-short);
        padding: var(--px-8);
        margin: calc(var(--px-8) * -1);
        border-radius: var(--px-4);
        text-decoration: none;
    }

    .header-search-cta:active {
        opacity: 1;
    }

    .header-search-cta:focus-visible {
        outline: 3px solid var(--color-focus);
        outline-offset: var(--px-2);
    }

    .header-search-icon {
        width: 1.375rem;
        height: 1.375rem;
    }

    .header-search-cta--desktop {
        display: inline-flex;
    }

    .header-search-cta--mobile {
        display: none;
    }

    .scrolled {
        height: var(--h-menu-bar-scrolled) !important;
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
        background: rgba(255, 255, 255, 0.98);
        color: var(--color-brand-navy);
        box-shadow: var(--shadow-header);
    }

    .mobile-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background-color: var(--color-overlay);
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        z-index: var(--z-50);
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

    .mobile-overlay.active {
        opacity: 1;
        visibility: visible;
    }

    .trigger {
        height: 1px;
    }

    @media (hover: hover) and (pointer: fine) {
        .nav-link:hover {
            opacity: 1;
        }

        .header-search-cta:hover {
            opacity: 1;
        }
    }

    @media screen and (max-width: 64rem) {
        .header {
            padding-inline: var(--px-16);
        }

        .logo-img--full {
            display: none;
        }

        .logo-img--mark {
            display: block;
        }

        .header-search-cta--desktop {
            display: none;
        }

        .header-search-cta--mobile {
            display: inline-flex;
        }

        .hamburger {
            display: flex;
        }

        .nav-content {
            z-index: var(--z-999);
            position: fixed;
            top: 0;
            right: -100%;
            height: 100vh;
            width: 100%;
            max-width: 18.75rem;
            background: white;
            color: var(--color-brand-navy);
            flex-direction: column;
            padding: calc(var(--h-menu-bar) + 2rem) var(--px-16) var(--px-32);
            transition: right 0.3s ease;
            box-shadow: -5px 0 15px rgba(0, 0, 0, 0.1);
            justify-content: flex-start;
        }

        .nav-content.active {
            right: 0;
        }

        .nav-menu {
            flex-direction: column;
            gap: var(--px-20);
            margin-bottom: var(--px-40);
            justify-content: flex-start;
        }

        .nav-item {
            margin: 0;
        }

        .nav-link:not(.header-search-cta) {
            font-size: var(--text-2xl);
        }

        .header-search-cta--mobile .header-search-icon {
            width: 1.625rem;
            height: 1.625rem;
        }

        .hamburger.active .hamburger-line:nth-child(1) {
            transform: translateY(0.438rem) rotate(45deg);
        }

        .hamburger.active .hamburger-line:nth-child(2) {
            opacity: 0;
        }

        .hamburger.active .hamburger-line:nth-child(3) {
            transform: translateY(-0.563rem) rotate(-45deg);
        }
    }
</style>

<script>
    function observeHeader() {
        const trigger = document.getElementById("trigger");
        const header = document.getElementById("header");

        if (!trigger || !header) return;

        const observer = new IntersectionObserver(
            ([entry]) => {
                header.classList.toggle("scrolled", !entry.isIntersecting);
            },
            { threshold: 0 },
        );

        observer.observe(trigger);

        return () => observer.disconnect();
    }

    function initMobileMenu() {
        const hamburger = document.querySelector(".hamburger");
        const navContent = document.querySelector(".nav-content");
        const overlay = document.querySelector(".mobile-overlay");

        if (!hamburger || !navContent || !overlay) return;

        function closeMenu() {
            hamburger?.classList.remove("active");
            navContent?.classList.remove("active");
            overlay?.classList.remove("active");
            hamburger?.setAttribute("aria-expanded", "false");
            document.body.classList.remove("no-scroll");
        }

        function openMenu() {
            hamburger?.classList.add("active");
            navContent?.classList.add("active");
            overlay?.classList.add("active");
            hamburger?.setAttribute("aria-expanded", "true");
            document.body.classList.add("no-scroll");
        }

        const toggleMenu = () => {
            hamburger.classList.contains("active") ? closeMenu() : openMenu();
        };

        const handleEscape = (e: KeyboardEvent) => {
            if (e.key === "Escape" && hamburger.classList.contains("active")) {
                closeMenu();
            }
        };

        navContent.addEventListener("click", (e) => {
            const el = (e.target as HTMLElement).closest(".nav-link");
            if (el) closeMenu();
        });

        hamburger.addEventListener("click", toggleMenu);
        overlay.addEventListener("click", closeMenu);
        document.addEventListener("keydown", handleEscape);

        return () => {
            hamburger.removeEventListener("click", toggleMenu);
            navContent.removeEventListener("click", closeMenu);
            overlay.removeEventListener("click", closeMenu);
            document.removeEventListener("keydown", handleEscape);
        };
    }

    let headerCleanup = observeHeader();
    let menuCleanup = initMobileMenu();

    document.addEventListener("astro:after-swap", () => {
        if (headerCleanup) headerCleanup();
        if (menuCleanup) menuCleanup();
        headerCleanup = observeHeader();
        menuCleanup = initMobileMenu();
    });
</script>

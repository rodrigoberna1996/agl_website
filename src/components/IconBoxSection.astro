---
import { Image } from "astro:assets";
import cocheImage      from "/src/assets/images/categories/coche.png";
import industriaImage  from "/src/assets/images/categories/industria.png";
import motoImage       from "/src/assets/images/categories/moto.png";
import transporteImage from "/src/assets/images/categories/transporte.png";

const iconBoxes = [
    {
        title: "Productos originales",
        description:
            "Lubricantes TotalEnergies y ELF con respaldo para cada aplicacion.",
        icon: "seal",
    },
    {
        title: "Atencion competitiva",
        description:
            "Cotizamos por volumen, presentacion y necesidad de cada operacion.",
        icon: "rate",
    },
    {
        title: "Amplia variedad",
        description:
            "Aceites, grasas y fluidos para motor, transmision e industria.",
        icon: "target",
    },
];

const productCategories = [
    { title: "Coche",      image: cocheImage },
    { title: "Moto",       image: motoImage },
    { title: "Transporte", image: transporteImage },
    { title: "Industria",  image: industriaImage },
];
---

<section class="ignavo-template-strip" aria-label="Beneficios y categorias">
    <div class="section-container">
        <div class="ignavo-feature-row">
            {
                iconBoxes.map((item) => (
                    <div class="ignavo-feature-column">
                        <div
                            class="site-iconbox items-center"
                            style="--iconbox-icon: 60px; --iconbox-title: 16px; --iconbox-title-mobile: 15px; --iconbox-title-font-weight: 600; --iconbox-description: 12px;"
                        >
                            <div class="site-iconbox-icon">
                                {item.icon === "seal" && (
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <path d="m8.5 15.5-1.2 5 4.7-2 4.7 2-1.2-5" />
                                        <circle cx="12" cy="9" r="6" />
                                        <path d="m9.5 9 1.7 1.7 3.3-3.7" />
                                    </svg>
                                )}
                                {item.icon === "rate" && (
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <path d="M12 3v18" />
                                        <path d="M17 7.5c-.8-1-2.2-1.6-4-1.6-2.3 0-4 .9-4 2.7 0 4.3 8 1.6 8 5.8 0 1.8-1.7 2.7-4 2.7-2 0-3.5-.7-4.4-1.9" />
                                        <path d="M4 12h3" />
                                        <path d="M17 12h3" />
                                    </svg>
                                )}
                                {item.icon === "target" && (
                                    <svg viewBox="0 0 24 24" fill="none">
                                        <circle cx="12" cy="12" r="8" />
                                        <circle cx="12" cy="12" r="4" />
                                        <path d="M12 2v3" />
                                        <path d="M12 19v3" />
                                        <path d="M2 12h3" />
                                        <path d="M19 12h3" />
                                    </svg>
                                )}
                            </div>
                            <div class="site-iconbox-detail">
                                <h4 class="entry-title">{item.title}</h4>
                                <p>{item.description}</p>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>

        <div
            class="site-scroll-snap"
            style="--scroll-grid-lg: 4; --scroll-grid-sm: 2; --scroll-grid-xs: 2; --scroll-gap: 10px; --scroll-gap-sm: 8px;"
        >
            {
                productCategories.map((category) => (
                    <div class="site-scroll-item">
                        <div class="site-category">
                            <div class="site-category-media">
                                <a href="/products" aria-label={`Ver productos para ${category.title}`}>
                                    <Image
                                        src={category.image}
                                        alt={category.title}
                                        width={300}
                                        height={300}
                                        loading="lazy"
                                        decoding="async"
                                    />
                                </a>
                            </div>
                            <div class="site-category-content">
                                <h4 class="entry-category-name">{category.title}</h4>
                            </div>
                            <a
                                href="/products"
                                class="wrap-link"
                                aria-label={`Ver ${category.title}`}
                            />
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    section.ignavo-template-strip {
        --colors-gray-50: 248, 250, 252;
        --colors-gray-100: 241, 245, 249;
        --colors-gray-200: 226, 232, 240;
        --colors-gray-500: 100, 116, 139;
        --colors-gray-600: 71, 85, 105;
        --colors-gray-900: 15, 23, 42;
        --colors-white: 255, 255, 255;
        --theme-radius: 8px;
        --theme-ease-in-out: ease;
        --theme-ease-time-fast: 0.18s;
        --theme-padding: 10px;
        --text-2xs: 0.6875rem;
        background: var(--color-white);
        padding: 0 var(--px-64) var(--px-64);
    }

    .ignavo-feature-row {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        border-top: 1px solid rgb(var(--colors-gray-200));
        margin-bottom: 20px;
    }

    .ignavo-feature-column {
        position: relative;
        display: flex;
        align-items: center;
        min-width: 0;
        padding: 22px 40px 0;
        min-height: 100px;
    }

    .ignavo-feature-column + .ignavo-feature-column {
        border-left: 0;
    }

    .ignavo-feature-column + .ignavo-feature-column::before {
        content: "";
        position: absolute;
        inset-inline-start: 0;
        top: 22px;
        bottom: 0;
        width: 1px;
        background: rgb(var(--colors-gray-200));
    }

    /* Copiado del template Ignavo: base.css / Iconbox */
    .site-iconbox {
        --iconbox-gap: 18px;
        --iconbox-row-gap: 6px;
        --iconbox-icon: 28px;
        --iconbox-icon-color: currentColor;
        --iconbox-title: 15px;
        --iconbox-title-mobile: 15px;
        --iconbox-title-font-weight: 500;
        --iconbox-title-margin: 2px;
        --iconbox-title-color: currentColor;
        --iconbox-description: 13px;
        --iconbox-description-color: rgb(var(--colors-gray-500));
        display: flex;
        flex-wrap: wrap;
        gap: var(--iconbox-gap);
        row-gap: var(--iconbox-row-gap);
    }

    .site-iconbox.items-center {
        align-items: center;
    }

    .site-iconbox .site-iconbox-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--color-brand-blue);
    }

    .site-iconbox .site-iconbox-icon > * {
        width: var(--iconbox-icon);
        height: auto;
    }

    .site-iconbox .site-iconbox-icon svg {
        stroke: currentColor;
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .site-iconbox .site-iconbox-detail {
        flex: 1 0 0%;
        min-width: 0;
    }

    .site-iconbox .site-iconbox-detail .entry-title {
        font-size: var(--iconbox-title-mobile);
        font-weight: var(--iconbox-title-font-weight);
        color: var(--iconbox-title-color);
        margin: 0 0 var(--iconbox-title-margin);
        line-height: 1.25;
    }

    .site-iconbox .site-iconbox-detail p {
        font-size: var(--iconbox-description);
        color: var(--iconbox-description-color);
        margin: 0;
        line-height: 1.45;
        opacity: 1;
    }

    @media screen and (min-width: 576.02px) {
        .site-iconbox .site-iconbox-detail .entry-title {
            font-size: var(--iconbox-title);
        }
    }

    /* Copiado del template Ignavo: base.css / Scroll snap */
    .site-scroll-snap {
        --scroll-gap: var(--theme-padding);
        --scroll-gap-mobile: 16px;
        --scroll-grid-lg: 4;
        --scroll-grid-sm: 2;
        --scroll-grid-xs: 1;
        display: flex;
        flex-wrap: nowrap;
        gap: var(--scroll-gap);
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scroll-snap-stop: always;
        scrollbar-width: none;
    }

    .site-scroll-snap::-webkit-scrollbar {
        display: none;
    }

    .site-scroll-snap > * {
        scroll-snap-align: start;
    }

    .site-scroll-snap > *:last-child {
        scroll-snap-align: end;
    }

    @media screen and (max-width: 575.98px) {
        .site-scroll-snap {
            --scroll-gap: var(--scroll-gap-mobile);
        }
    }

    .site-scroll-snap:not(.custom-width) .site-scroll-item {
        flex: 0 0 auto;
        width: calc(
            (100% - (var(--scroll-grid-xs) - 0.6666666667) * var(--scroll-gap)) /
                (var(--scroll-grid-xs) + 0.3333333333)
        );
    }

    .site-scroll-snap:not(.custom-width) .site-scroll-item:last-child {
        margin-inline-end: calc(var(--scroll-gap) * -1);
    }

    @media screen and (min-width: 576.02px) {
        .site-scroll-snap:not(.custom-width) .site-scroll-item {
            width: calc(
                (100% - (var(--scroll-grid-sm) - 0.6666666667) * var(--scroll-gap)) /
                    (var(--scroll-grid-sm) + 0.3333333333)
            );
        }
    }

    @media screen and (min-width: 1024.02px) {
        .site-scroll-snap:not(.custom-width) .site-scroll-item {
            width: calc(
                (100% - (var(--scroll-grid-lg) - 1) * var(--scroll-gap)) /
                    var(--scroll-grid-lg)
            );
        }
    }

    /* Copiado del template Ignavo: base.css / Category */
    .site-category {
        --category-foreground: rgb(var(--colors-gray-900));
        --category-background: rgb(var(--colors-gray-100));
        --category-border: transparent;
        --category-foreground-hover: rgb(var(--colors-gray-900));
        --category-background-hover: rgb(var(--colors-gray-50));
        --category-border-hover: transparent;
        --category-muted-foreground: rgb(var(--colors-gray-500));
        --category-border-radius: var(--theme-radius);
        --category-shadow: none;
        --category-media-padding: 8px;
        --category-media-size: 102px;
        --category-content-padding: 10px;
        --category-content-align: center;
        --categor-name-size: 15px;
        --category-name-weight: 600;
        position: relative;
        height: 100%;
        background-color: var(--category-background);
        border: 1px solid var(--category-border);
        border-radius: var(--category-border-radius);
        box-shadow: var(--category-shadow);
        transition-property: color, background-color, border-color;
        transition-timing-function: var(--theme-ease-in-out);
        transition-duration: var(--theme-ease-time-fast);
    }

    .site-category:hover {
        background-color: var(--category-background-hover);
        border-color: var(--category-border-hover);
        color: var(--category-foreground-hover);
    }

    .site-category .site-category-media a {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: var(--category-media-size);
        padding: var(--category-media-padding);
        overflow: visible;
        border-radius: var(--category-border-radius) var(--category-border-radius) 0 0;
    }

    .site-category .site-category-media a > * {
        display: block;
        max-width: 100%;
    }

    :global(.site-category .site-category-media img) {
        display: block;
        width: auto !important;
        height: auto !important;
        max-width: 100% !important;
        max-height: var(--category-media-size) !important;
        object-fit: contain !important;
        object-position: center !important;
        margin: 0 auto !important;
    }

    .site-category .site-category-content {
        display: flex;
        flex-direction: column;
        align-items: var(--category-content-align);
        color: var(--category-foreground);
        padding: var(--category-content-padding);
    }

    .site-category .site-category-content .entry-category-name {
        font-size: var(--categor-name-size);
        font-weight: var(--category-name-weight);
        margin: 0;
        line-height: 1.25;
    }

    .site-category .site-category-content .entry-category-count {
        font-size: var(--text-2xs);
        font-weight: 500;
        color: var(--category-muted-foreground);
        line-height: 1;
    }

    .site-category .wrap-link {
        position: absolute;
        inset: 0;
        z-index: 2;
    }

    @media screen and (max-width: 64rem) {
        section.ignavo-template-strip {
            padding-inline: var(--px-32);
            padding-bottom: var(--px-56);
        }

        .ignavo-feature-row {
            grid-template-columns: 1fr;
            margin-bottom: 16px;
        }

        .ignavo-feature-column {
            min-height: auto;
            padding: 22px 0 16px;
        }

        .ignavo-feature-column + .ignavo-feature-column {
            border-top: 1px solid rgb(var(--colors-gray-200));
        }

        .ignavo-feature-column + .ignavo-feature-column::before {
            display: none;
        }
    }

    @media screen and (max-width: 42rem) {
        section.ignavo-template-strip {
            padding-inline: var(--px-20);
            padding-bottom: var(--px-48);
        }

        .site-iconbox {
            --iconbox-icon: 44px;
            --iconbox-gap: 14px;
        }

        .site-category {
            --category-media-size: 84px;
            --category-media-padding: 4px;
            --category-content-padding: 8px;
        }
    }
</style>

---
import { Image } from "astro:assets";
import { getCatalogItems, CATEGORY_LABELS, getProductUrl } from "@lib/catalog";
import type { ProductCategory } from "@lib/catalog";

const items = getCatalogItems();

const counts: Record<string, number> = { all: items.length };
for (const item of items) {
    counts[item.category] = (counts[item.category] ?? 0) + 1;
}

const filters: { key: string; label: string; count: number }[] = [
    { key: "all", label: "Todos", count: counts.all },
    ...(Object.entries(CATEGORY_LABELS) as [ProductCategory, string][]).map(
        ([key, label]) => ({ key, label, count: counts[key] ?? 0 }),
    ),
];
---

<section class="product-list-section" aria-labelledby="product-list-heading">
    <div class="section-container">

        <!-- ─── Page header ─── -->
        <header class="pl-header">
            <span class="section-tag">Catálogo</span>
            <h1 id="product-list-heading" class="section-title pl-header__title">
                Nuestros productos
            </h1>
            <p class="pl-header__desc">
                Línea completa de aceites, lubricantes y grasas
                <strong>TotalEnergies</strong> y <strong>ELF</strong> para motor, industrial,
                transmisión y más. Cotiza con nosotros.
            </p>
        </header>

        <!-- ─── Toolbar: filtros + búsqueda ─── -->
        <div class="pl-toolbar">
            <nav class="pl-filters" aria-label="Filtrar por categoría" role="group">
                {filters.map((f) => (
                    <button
                        class:list={["pl-filter-btn", { active: f.key === "all" }]}
                        data-filter={f.key}
                        type="button"
                        aria-pressed={f.key === "all" ? "true" : "false"}
                    >
                        {f.label}
                        <span class="pl-filter-count">{f.count}</span>
                    </button>
                ))}
            </nav>

            <div class="pl-search">
                <label class="sr-only" for="product-search">Buscar producto</label>
                <div class="pl-search__field">
                    <svg class="pl-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.3-4.3" />
                    </svg>
                    <input
                        id="product-search"
                        type="search"
                        class="pl-search__input"
                        placeholder="Buscar por nombre o descripción…"
                        autocomplete="off"
                    />
                </div>
            </div>
        </div>

        <!-- ─── Results count ─── -->
        <p class="pl-results-count" id="pl-results-count" aria-live="polite">
            <span id="pl-count-num">{items.length}</span> producto{items.length !== 1 ? "s" : ""}
        </p>

        <!-- ─── Grid ─── -->
        {
            items.length === 0 ? (
                <div class="pl-empty">
                    <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                        <rect x="4" y="8" width="40" height="32" rx="4" stroke="currentColor" stroke-width="2"/>
                        <path d="M16 8v4M32 8v4M4 20h40" stroke="currentColor" stroke-width="2"/>
                        <path d="M16 28h4M28 28h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                    <p>No hay productos en el catálogo por el momento.</p>
                </div>
            ) : (
                <ul class="pl-grid" id="product-grid" role="list">
                    {items.map((item) => (
                        <li
                            class="pl-item"
                            data-category={item.category}
                            data-search={`${item.name} ${item.description} ${item.brand} ${item.sku}`.toLowerCase()}
                        >
                            <article class="pl-card">
                                <a href={getProductUrl(item.slug)} class="pl-card__image-link" tabindex="-1" aria-hidden="true">
                                    <div class="pl-card__media">
                                        <span class:list={["pl-card__brand-badge", `badge--${item.brand.toLowerCase()}`]}>
                                            {item.brand}
                                        </span>
                                        <Image
                                            class="pl-card__image"
                                            src={item.image}
                                            alt={item.name}
                                            width={320}
                                            height={320}
                                            loading="lazy"
                                            decoding="async"
                                            sizes="(max-width: 42rem) 50vw, (max-width: 64rem) 33vw, 25vw"
                                        />
                                    </div>
                                </a>

                                <div class="pl-card__body">
                                    <div class="pl-card__meta">
                                        <span class="pl-card__category">
                                            {CATEGORY_LABELS[item.category]}
                                        </span>
                                        <span class="pl-card__sku">#{item.sku}</span>
                                    </div>

                                    <h3 class="pl-card__name">
                                        <a href={getProductUrl(item.slug)} class="pl-card__name-link">
                                            {item.name}
                                        </a>
                                    </h3>

                                    <p class="pl-card__desc">{item.description}</p>

                                    <div class="pl-card__footer">
                                        <span class="pl-card__quote">Cotizar precio</span>
                                        <a href={getProductUrl(item.slug)} class="pl-card__cta">
                                            Ver detalle
                                            <svg viewBox="0 0 16 16" fill="none" aria-hidden="true">
                                                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                        </a>
                                    </div>
                                </div>
                            </article>
                        </li>
                    ))}
                </ul>
            )
        }

        <!-- ─── Empty states ─── -->
        <div class="pl-empty pl-filter-empty" id="pl-filter-empty" hidden>
            <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="2"/>
                <path d="M16 24h16M24 16v16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <p>No hay productos en esta categoría.</p>
        </div>

        <div class="pl-empty pl-search-empty" id="pl-search-empty" hidden>
            <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <circle cx="20" cy="20" r="14" stroke="currentColor" stroke-width="2"/>
                <path d="m30 30 8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <p>No se encontraron productos para su búsqueda.</p>
        </div>

    </div>
</section>

<style>
    /* ── Section shell ── */
    section.product-list-section {
        background: var(--color-background);
        padding-top: calc(var(--h-menu-bar) + var(--px-64));
        padding-bottom: var(--px-96);
    }

    /* ── sr-only ── */
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    /* ── Page header ── */
    .pl-header {
        max-width: 48rem;
        margin-bottom: var(--px-48);
    }

    /* .section-tag is a global utility — no custom tag styles needed */

    /* extends global .section-title, adds letter-spacing */
    .pl-header__title {
        letter-spacing: -0.02em;
    }

    .pl-header__desc {
        margin: 0;
        font-size: var(--text-sm);
        line-height: 1.65;
        color: var(--color-text-secondary);
        opacity: 1;
        max-width: 42rem;
    }

    .pl-header__desc strong {
        color: var(--color-text-primary);
        font-weight: 600;
    }

    /* ── Toolbar ── */
    .pl-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--px-16) var(--px-24);
        flex-wrap: wrap;
        margin-bottom: var(--px-32);
    }

    /* ── Filter pills — igual al patrón de PortfolioPage ── */
    .pl-filters {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--px-10);
        flex: 1 1 auto;
        min-width: 0;
    }

    .pl-filter-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--px-8);
        padding: var(--px-10) var(--px-20);
        min-height: 2.75rem;
        border: 1px solid var(--color-border);
        border-radius: 999px;
        background: var(--color-white);
        color: var(--color-text-primary);
        font-size: var(--text-sm);
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition:
            background var(--transition-short),
            border-color var(--transition-short),
            color var(--transition-short);
    }

    .pl-filter-btn.active {
        background: var(--color-brand-blue);
        border-color: var(--color-brand-blue);
        color: var(--color-white);
    }

    .pl-filter-count {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 700;
        background: rgba(0, 0, 0, 0.07);
        border-radius: 999px;
        padding: 0.1rem 0.42rem;
        line-height: 1.7;
        min-width: 1.3rem;
        text-align: center;
        transition:
            background var(--transition-short),
            color var(--transition-short);
        color: var(--color-text-secondary);
    }

    .pl-filter-btn.active .pl-filter-count {
        background: rgba(255, 255, 255, 0.22);
        color: var(--color-white);
    }

    /* ── Search ── */
    .pl-search {
        flex: 0 1 18rem;
        min-width: min(100%, 14rem);
    }

    .pl-search__field {
        position: relative;
    }

    .pl-search__icon {
        position: absolute;
        left: var(--px-16);
        top: 50%;
        transform: translateY(-50%);
        width: 1.125rem;
        height: 1.125rem;
        color: var(--color-text-secondary);
        pointer-events: none;
    }

    .pl-search__input {
        width: 100%;
        min-height: 2.75rem;
        padding: var(--px-10) var(--px-16) var(--px-10) calc(var(--px-16) + 1.5rem);
        background: var(--color-white);
        border: 1px solid var(--color-border);
        border-radius: var(--px-8);
        font-size: var(--text-sm);
        color: var(--color-text-primary);
        transition: border-color var(--transition-short), box-shadow var(--transition-short);
        outline: none;
    }

    .pl-search__input::placeholder {
        color: var(--color-text-secondary);
        opacity: 0.75;
    }

    .pl-search__input:focus {
        border-color: var(--color-border-focus);
        box-shadow: 0 0 0 3px rgba(0, 193, 206, 0.16);
    }

    /* ── Results count ── */
    .pl-results-count {
        margin: 0 0 var(--px-24);
        font-size: 0.8rem;
        color: var(--color-text-secondary);
        opacity: 1;
    }

    /* ── Grid ── */
    .pl-grid {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--px-20);
    }

    /* ── Card ── */
    .pl-card {
        display: flex;
        flex-direction: column;
        background: var(--color-white);
        border: 1px solid var(--color-border);
        border-radius: var(--px-16);
        overflow: hidden;
        height: 100%;
        transition:
            box-shadow var(--transition-medium),
            transform var(--transition-medium),
            border-color var(--transition-medium);
    }

    /* image link wrapper */
    .pl-card__image-link {
        display: block;
        text-decoration: none;
    }

    .pl-card__media {
        position: relative;
        aspect-ratio: 1;
        overflow: hidden;
        background: #f3f7fd;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pl-card__image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
        padding: var(--px-20);
        transition: transform var(--transition-medium);
    }

    /* brand badge */
    .pl-card__brand-badge {
        position: absolute;
        top: var(--px-10);
        left: var(--px-10);
        z-index: 2;
        font-size: 0.62rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        padding: 0.2rem 0.5rem;
        border-radius: var(--radius-sm);
        line-height: 1.5;
    }

    .badge--total {
        background: rgba(237, 26, 58, 0.1);
        color: var(--color-brand-red);
    }

    .badge--elf {
        background: rgba(3, 78, 162, 0.12);
        color: var(--color-brand-blue);
    }

    /* body */
    .pl-card__body {
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: var(--px-14) var(--px-16) var(--px-16);
        gap: var(--px-6);
        border-top: 1px solid rgba(3, 78, 162, 0.07);
    }

    .pl-card__meta {
        display: flex;
        align-items: center;
        gap: var(--px-6);
        flex-wrap: wrap;
    }

    .pl-card__category {
        font-size: 0.66rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 0.18rem 0.45rem;
        border-radius: var(--radius-sm);
        background: rgba(3, 78, 162, 0.07);
        color: var(--color-brand-blue);
        line-height: 1.6;
    }

    .pl-card__sku {
        font-size: 0.66rem;
        font-weight: 500;
        color: var(--color-text-secondary);
        opacity: 0.6;
        letter-spacing: 0.02em;
    }

    .pl-card__name {
        margin: 0;
        font-size: 0.9rem;
        font-weight: 600;
        line-height: 1.35;
        color: var(--color-text-primary);
        letter-spacing: -0.01em;
    }

    .pl-card__name-link {
        color: inherit;
        text-decoration: none;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .pl-card__desc {
        margin: 0;
        font-size: 0.78rem;
        line-height: 1.5;
        color: var(--color-text-secondary);
        opacity: 0.85;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* footer */
    .pl-card__footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--px-8);
        margin-top: auto;
        padding-top: var(--px-12);
        border-top: 1px solid rgba(0, 0, 0, 0.05);
    }

    .pl-card__quote {
        font-size: 0.78rem;
        font-weight: 700;
        color: #0f9f6e;
        white-space: nowrap;
    }

    .pl-card__cta {
        display: inline-flex;
        align-items: center;
        gap: var(--px-4);
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--color-brand-blue);
        text-decoration: none;
        white-space: nowrap;
        transition: gap var(--transition-short), color var(--transition-short);
    }

    .pl-card__cta svg {
        width: 0.875rem;
        height: 0.875rem;
        flex-shrink: 0;
        transition: transform var(--transition-short);
    }

    /* ── Empty states ── */
    .pl-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--px-16);
        padding: var(--px-80) 0;
        color: var(--color-text-secondary);
        opacity: 0.55;
    }

    .pl-empty svg {
        width: 3rem;
        height: 3rem;
    }

    .pl-empty p {
        margin: 0;
        font-size: var(--text-sm);
        opacity: 1;
    }

    /* ── Hover ── */
    @media (hover: hover) and (pointer: fine) {
        .pl-filter-btn:not(.active):hover {
            background: rgba(3, 78, 162, 0.06);
            border-color: var(--color-border-hover);
            color: var(--color-brand-blue);
        }

        .pl-card:hover {
            box-shadow: 0 8px 28px rgba(3, 78, 162, 0.12), 0 2px 6px rgba(0, 0, 0, 0.04);
            transform: translateY(-3px);
            border-color: var(--color-border-hover);
        }

        .pl-card:hover .pl-card__image {
            transform: scale(1.04);
        }

        .pl-card:hover .pl-card__name-link {
            color: var(--color-brand-blue);
        }

        .pl-card__cta:hover {
            color: var(--color-brand-red);
            gap: var(--px-8);
        }

        .pl-card__cta:hover svg {
            transform: translateX(2px);
        }
    }

    /* ── Tablet ── */
    @media screen and (max-width: 64rem) {
        section.product-list-section {
            padding-top: calc(var(--h-menu-bar) + var(--px-56));
            padding-bottom: var(--px-80);
        }

        .pl-toolbar {
            flex-direction: column;
            align-items: stretch;
        }

        .pl-search {
            flex: 1 1 auto;
            max-width: none;
        }

        .pl-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: var(--px-16);
        }
    }

    /* ── Small tablet ── */
    @media screen and (max-width: 52rem) {
        .pl-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: var(--px-14);
        }
    }

    /* ── Mobile ── */
    @media screen and (max-width: 42.188rem) {
        section.product-list-section {
            padding-top: calc(var(--h-menu-bar) + var(--px-40));
            padding-bottom: var(--px-64);
        }

        .pl-header {
            margin-bottom: var(--px-32);
        }

        .pl-filter-btn {
            font-size: 0.8rem;
            padding: var(--px-6) var(--px-12);
        }

        .pl-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: var(--px-12);
        }

        .pl-card__body {
            padding: var(--px-10) var(--px-12) var(--px-12);
            gap: var(--px-4);
        }

        .pl-card__desc {
            display: none;
        }

        .pl-card__sku {
            display: none;
        }
    }
</style>

<script>
    function initProductList() {
        const filterBtns = document.querySelectorAll<HTMLButtonElement>(".pl-filter-btn");
        const items = document.querySelectorAll<HTMLLIElement>(".pl-item");
        const searchInput = document.getElementById("product-search") as HTMLInputElement | null;
        const filterEmpty = document.getElementById("pl-filter-empty");
        const searchEmpty = document.getElementById("pl-search-empty");
        const countEl = document.getElementById("pl-count-num");

        if (!filterBtns.length && !searchInput) return;

        let activeFilter = "all";
        let searchQuery = "";

        function updateVisibility() {
            let visible = 0;

            items.forEach((item) => {
                const matchFilter = activeFilter === "all" || item.dataset.category === activeFilter;
                const matchSearch = !searchQuery || (item.dataset.search ?? "").includes(searchQuery);
                const show = matchFilter && matchSearch;

                if (show) {
                    item.removeAttribute("hidden");
                    visible++;
                } else {
                    item.setAttribute("hidden", "");
                }
            });

            if (countEl) countEl.textContent = String(visible);

            const isSearching = searchQuery.length > 0;
            const isFiltering = activeFilter !== "all";

            if (filterEmpty) filterEmpty.hidden = !(visible === 0 && isFiltering && !isSearching);
            if (searchEmpty) searchEmpty.hidden = !(visible === 0 && isSearching);
        }

        filterBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                activeFilter = btn.dataset.filter ?? "all";

                filterBtns.forEach((b) => {
                    b.classList.toggle("active", b === btn);
                    b.setAttribute("aria-pressed", b === btn ? "true" : "false");
                });

                updateVisibility();
            });
        });

        if (searchInput) {
            searchInput.addEventListener("input", () => {
                searchQuery = searchInput.value.trim().toLowerCase();
                updateVisibility();
            });
        }
    }

    initProductList();
    document.addEventListener("astro:after-swap", initProductList);
</script>

---
import BaseSwiper from "./BaseSwiper.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import agl43HeroImage from "/src/assets/images/hero/hero_2.jpg";
import { getPortfolioProjects } from "@lib/wordpress";

interface Props {
    /** Oculta la etiqueta PORTFOLIO y el título (p. ej. cuando va encima del bloque de video). */
    hideSectionHeading?: boolean;
}

const { hideSectionHeading = false } = Astro.props;

type ProjectImage = {
    src: ImageMetadata | string;
    alt: string;
};

type Project = {
    id: number;
    images: {
        after: ProjectImage;
    };
    info: {
        challenge: { title: string; text: string };
        result: { title: string; text: string };
    };
};

/** Primera vista del carrusel `#hero`: referencia de producto AGL. */
const heroSpotlight: Project = {
    id: 0,
    images: {
        after: {
            src: agl43HeroImage,
            alt: "Producto AGL Legaspi — referencia de catálogo",
        },
    },
    info: {
        challenge: {
            title: "Todas tus soluciones de lubricación en un solo distribuidor",
            text: "Aceites, grasas y fluidos TotalEnergies y ELF para talleres, flotillas, transporte e industria.",
        },
        result: {
            title: "AGL Legaspi",
            text: "Cobertura en CDMX, Estado de México, Morelos y zonas cercanas, con asesoría técnica para elegir el producto correcto.",
        },
    },
};

const fallbackProjects: Project[] = [
    {
        id: 1,
        images: {
            after: {
                src: agl43HeroImage,
                alt: "Producto AGL Legaspi — referencia de catálogo",
            },
        },
        info: {
            challenge: {
                title: "Quartz para cada tipo de motor",
                text: "Productos diseñados para proteger motores modernos, gasolina, diesel y aplicaciones de alto rendimiento.",
            },
            result: {
                title: "Automotriz",
                text: "Ayudamos a talleres y refaccionarias a seleccionar viscosidad, tecnología y disponibilidad según aplicación.",
            },
        },
    },
    {
        id: 2,
        images: {
            after: {
                src: agl43HeroImage,
                alt: "Producto AGL Legaspi — referencia de catálogo",
            },
        },
        info: {
            challenge: {
                title: "Rubia para transporte y trabajo pesado",
                text: "Lubricantes para motores diesel, flotillas, autobuses y maquinaria que requieren rendimiento constante.",
            },
            result: {
                title: "Servicio pesado",
                text: "Soporte para operaciones que necesitan continuidad, protección del equipo y entregas confiables.",
            },
        },
    },
];

const staticProjects: Project[] = [heroSpotlight, ...fallbackProjects];

const wpProjects = await getPortfolioProjects();

const wpMapped: Project[] | null =
    wpProjects && wpProjects.length > 0
        ? wpProjects.map((p) => ({
              id: p.id,
              images: {
                  after: {
                      src: p.acf.after_image ? p.acf.after_image.url : "",
                      alt: p.acf.after_image ? p.acf.after_image.alt : "",
                  },
              },
              info: {
                  challenge: {
                      title: p.acf.challenge_title || "Client's Challenge",
                      text: p.acf.challenge_text,
                  },
                  result: {
                      title: p.acf.result_title || "Result",
                      text: p.acf.result_text,
                  },
              },
          }))
        : null;

const projectSource: Project[] = wpMapped
    ? [heroSpotlight, ...wpMapped]
    : staticProjects;

const projects: Project[] = projectSource.map((project, index) =>
    index === 0
        ? project
        : {
              ...project,
              images: heroSpotlight.images,
          },
);

const getImageDimensions = (src: ImageMetadata | string) => {
    if (typeof src === "string") {
        return { width: 1144, height: 800 };
    }

    const width = Math.min(src.width, 1144);

    return {
        width,
        height: Math.round((width * src.height) / src.width),
    };
};
---

<section id="hero" class="portfolio">
    <div class="section-container">
        {
            !hideSectionHeading && (
                <>
                    <span class="section-tag">PORTFOLIO</span>
                    <h2 class="section-title">See the transformation.</h2>
                </>
            )
        }
        <BaseSwiper sliderName="portfolio" navigation={false}>
            {
                projects.map((project, index) => {
                    const imageDimensions = getImageDimensions(
                        project.images.after.src,
                    );

                    return (
                        <div class="swiper-slide">
                            <div class="project-image">
                                {typeof project.images.after.src === "string" ? (
                                    <img
                                        class="image"
                                        src={project.images.after.src}
                                        alt={project.images.after.alt}
                                        width={imageDimensions.width}
                                        height={imageDimensions.height}
                                        loading={index === 0 ? "eager" : "lazy"}
                                        decoding="async"
                                    />
                                ) : (
                                    <Image
                                        class="image"
                                        src={project.images.after.src}
                                        alt={project.images.after.alt}
                                        width={imageDimensions.width}
                                        height={imageDimensions.height}
                                        loading={index === 0 ? "eager" : "lazy"}
                                        decoding="async"
                                    />
                                )}
                            </div>
                            <div class="project-info">
                                <div class="info-section">
                                    <h3 class="section-subtitle info-title">
                                        {project.info.challenge.title}
                                    </h3>
                                    <p class="info-text">
                                        {project.info.challenge.text}
                                    </p>
                                </div>
                                <div class="info-section">
                                    <h3 class="section-subtitle info-title">
                                        {project.info.result.title}
                                    </h3>
                                    <p class="info-text">
                                        {project.info.result.text}
                                    </p>
                                </div>
                            </div>
                        </div>
                    );
                })
            }
        </BaseSwiper>
    </div>
</section>

<style>
    /* Sin flechas: sin padding lateral extra en el swiper */
    :global(#hero.portfolio .portfolio-showcase) {
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    :global(#hero.portfolio .portfolio-swiper) {
        width: 100%;
        padding-inline: 0;
        position: relative;
        height: clamp(26rem, 52svh, 36rem);
    }

    :global(#hero.portfolio .portfolio-swiper .swiper-wrapper) {
        height: 100%;
        align-items: stretch;
    }

    :global(#hero.portfolio .portfolio-swiper .swiper-slide) {
        height: 100%;
        box-sizing: border-box;
    }

    .swiper-slide {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(22rem, 1fr);
        align-items: stretch;
        gap: 0;
        opacity: 0;
        transform: scale(0.75);
        transition: all var(--transition-long);
        height: 100%;
        box-sizing: border-box;
        min-height: 100%;
    }

    .swiper-slide-active {
        opacity: 1;
        transform: scale(1);
    }

    .swiper-slide-prev,
    .swiper-slide-next {
        opacity: 0;
        transform: scale(0.75);
    }

    .project-image {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        overflow: hidden;
        padding: 0;
        background: #f3f6fa;
        border-radius: 0;
    }

    .image {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
        object-position: center;
        filter: none;
    }

    .project-info {
        min-height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: clamp(var(--px-24), 3vw, var(--px-36));
        overflow-y: auto;
        overflow-x: hidden;
        padding: clamp(var(--px-36), 5vw, var(--px-64));
        box-sizing: border-box;
        background: var(--color-white);
        border-left: 4px solid var(--color-brand-red);
    }

    .info-section {
        display: flex;
        flex-direction: column;
        gap: var(--px-12);
        flex-shrink: 0;
    }

    .info-section + .info-section {
        padding-top: clamp(var(--px-8), 1vw, var(--px-16));
    }

    .info-text {
        margin: 0;
        max-width: 40rem;
        color: var(--color-text-secondary);
        font-size: clamp(0.95rem, 1vw, 1rem);
        line-height: 1.6;
        overflow-wrap: anywhere;
    }

    .info-title {
        margin-bottom: 0;
        max-width: 40rem;
        color: var(--color-brand-navy);
        line-height: 1.22;
        letter-spacing: normal;
        text-wrap: balance;
    }

    .info-section:first-child .info-title {
        font-size: clamp(1.5rem, 2.2vw, 2.5rem);
    }

    @media screen and (max-width: 64rem) {
        .swiper-slide {
            grid-template-columns: minmax(0, 1fr) minmax(20rem, 1fr);
            gap: 0;
        }

        .project-info {
            padding: var(--px-32) var(--px-28);
        }
    }

    @media screen and (max-width: 55rem) {
        /* Libera el height fijo del swiper para que autoHeight funcione */
        :global(#hero.portfolio .portfolio-swiper) {
            height: auto;
            min-height: 0;
        }

        :global(#hero.portfolio .portfolio-swiper .swiper-wrapper),
        :global(#hero.portfolio .portfolio-swiper .swiper-slide) {
            height: auto;
        }

        /* En móvil: columna única, imagen arriba con proporción fija, texto debajo */
        .swiper-slide {
            grid-template-columns: 1fr;
            grid-template-rows: auto auto;
            gap: 0;
            height: auto;
        }

        .project-image {
            width: 100%;
        }

        /* Texto debajo: tarjeta legible con fondo */
        .project-info {
            display: flex;
            justify-content: flex-start;
            padding: var(--px-24) var(--px-20) var(--px-28);
            gap: var(--px-20);
            overflow-y: visible;
            background-color: var(--color-white);
            border-left: none;
            border-top: 5px solid var(--color-brand-red);
        }
    }
</style>

<script>
    import { initSwiper } from "@utils/initSwiper";

    function initPortfolioSlider() {
        const portfolioSwiper = initSwiper("portfolio", {
            autoHeight: true,
            spaceBetween: 30,
            autoplay: {
                delay: 5200,
                disableOnInteraction: false,
            },
            pagination: {
                el: ".portfolio-pagination",
                clickable: true,
            },
        });

        const updatePortfolioLayout = () => {
            requestAnimationFrame(() => {
                portfolioSwiper.update();
                portfolioSwiper.updateAutoHeight(0);
            });
        };

        updatePortfolioLayout();
        window.setTimeout(updatePortfolioLayout, 150);

        document
            .querySelectorAll<HTMLImageElement>(".portfolio-swiper img")
            .forEach((image) => {
                if (image.complete) return;
                image.addEventListener("load", updatePortfolioLayout, {
                    once: true,
                });
            });

        return () => {
            portfolioSwiper.destroy();
        };
    }

    let cleanup = initPortfolioSlider();

    document.addEventListener("astro:after-swap", () => {
        if (cleanup) cleanup();
        cleanup = initPortfolioSlider();
    });
</script>

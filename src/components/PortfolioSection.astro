---
import BaseSwiper from "./BaseSwiper.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import agl43HeroImage from "/src/assets/images/hero/hero_2.jpg";
import { getPortfolioProjects } from "@lib/wordpress";

interface Props {
    /** Oculta la etiqueta PORTFOLIO y el título (p. ej. cuando va encima del bloque de video). */
    hideSectionHeading?: boolean;
}

const { hideSectionHeading = false } = Astro.props;

type ProjectImage = {
    src: ImageMetadata | string;
    alt: string;
};

type Project = {
    id: number;
    images: {
        after: ProjectImage;
    };
    info: {
        challenge: { title: string; text: string };
        result: { title: string; text: string };
    };
};

/** Primera vista del carrusel `#hero`: referencia de producto AGL. */
const heroSpotlight: Project = {
    id: 0,
    images: {
        after: {
            src: agl43HeroImage,
            alt: "Producto AGL Legaspi — referencia de catálogo",
        },
    },
    info: {
        challenge: {
            title: "Lubricantes y aceites profesionales",
            text: "Soluciones AGL Legaspi para talleres, flotillas e industria, con productos TotalEnergies ELF y asesoría para elegir el lubricante adecuado.",
        },
        result: {
            title: "Cobertura y atención confiable",
            text: "Atendemos CDMX, Estado de México, Morelos y zonas cercanas con disponibilidad, seguimiento y soporte especializado.",
        },
    },
};

const fallbackProjects: Project[] = [1, 2].map((id) => ({
    ...heroSpotlight,
    id,
}));

const staticProjects: Project[] = [heroSpotlight, ...fallbackProjects];

const wpProjects = await getPortfolioProjects();

const wpMapped: Project[] | null =
    wpProjects && wpProjects.length > 0
        ? wpProjects.map((p) => ({
              id: p.id,
              images: {
                  after: {
                      src: p.acf.after_image ? p.acf.after_image.url : "",
                      alt: p.acf.after_image ? p.acf.after_image.alt : "",
                  },
              },
              info: {
                  challenge: {
                      title: p.acf.challenge_title || "Client's Challenge",
                      text: p.acf.challenge_text,
                  },
                  result: {
                      title: p.acf.result_title || "Result",
                      text: p.acf.result_text,
                  },
              },
          }))
        : null;

const projects: Project[] = wpMapped
    ? [heroSpotlight, ...wpMapped]
    : staticProjects;

const getImageDimensions = (src: ImageMetadata | string) => {
    if (typeof src === "string") {
        return { width: 1144, height: 800 };
    }

    const width = Math.min(src.width, 1144);

    return {
        width,
        height: Math.round((width * src.height) / src.width),
    };
};
---

<section id="hero" class="portfolio">
    <div class="section-container">
        {
            !hideSectionHeading && (
                <>
                    <span class="section-tag">PORTFOLIO</span>
                    <h2 class="section-title">See the transformation.</h2>
                </>
            )
        }
        <BaseSwiper sliderName="portfolio" navigation={false}>
            {
                projects.map((project, index) => {
                    const imageDimensions = getImageDimensions(
                        project.images.after.src,
                    );

                    return (
                        <div class="swiper-slide">
                            <div
                                class="project-image"
                                style={`--image-aspect: ${imageDimensions.width} / ${imageDimensions.height}`}
                            >
                                {typeof project.images.after.src === "string" ? (
                                    <img
                                        class="image"
                                        src={project.images.after.src}
                                        alt={project.images.after.alt}
                                        width={imageDimensions.width}
                                        height={imageDimensions.height}
                                        loading={index === 0 ? "eager" : "lazy"}
                                        decoding="async"
                                    />
                                ) : (
                                    <Image
                                        class="image"
                                        src={project.images.after.src}
                                        alt={project.images.after.alt}
                                        width={imageDimensions.width}
                                        height={imageDimensions.height}
                                        loading={index === 0 ? "eager" : "lazy"}
                                        decoding="async"
                                    />
                                )}
                            </div>
                            <div class="project-info">
                                <div class="info-section">
                                    <h3 class="section-subtitle info-title">
                                        {project.info.challenge.title}
                                    </h3>
                                    <p class="info-text">
                                        {project.info.challenge.text}
                                    </p>
                                </div>
                                <div class="info-section">
                                    <h3 class="section-subtitle info-title">
                                        {project.info.result.title}
                                    </h3>
                                    <p class="info-text">
                                        {project.info.result.text}
                                    </p>
                                </div>
                            </div>
                        </div>
                    );
                })
            }
        </BaseSwiper>
    </div>
</section>

<style>
    /* Sin flechas: sin padding lateral extra en el swiper */
    :global(#hero.portfolio .portfolio-showcase) {
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    :global(#hero.portfolio .portfolio-swiper) {
        width: 100%;
        padding-inline: 0;
        position: relative;
        height: auto;
    }

    :global(#hero.portfolio .portfolio-swiper .swiper-wrapper) {
        height: auto;
        align-items: center;
    }

    :global(#hero.portfolio .portfolio-swiper .swiper-slide) {
        height: auto;
        box-sizing: border-box;
    }

    .swiper-slide {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.85fr);
        align-items: center;
        gap: clamp(var(--px-32), 4vw, var(--px-64));
        opacity: 0;
        transform: scale(0.75);
        transition: all var(--transition-long);
        height: auto;
        box-sizing: border-box;
    }

    .swiper-slide-active {
        opacity: 1;
        transform: scale(1);
    }

    .swiper-slide-prev,
    .swiper-slide-next {
        opacity: 0;
        transform: scale(0.75);
    }

    .project-image {
        position: relative;
        width: 100%;
        aspect-ratio: var(--image-aspect);
        overflow: hidden;
    }

    .image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
    }

    .project-info {
        min-height: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: clamp(var(--px-32), 4vw, var(--px-48));
        overflow-y: auto;
        overflow-x: hidden;
        padding: clamp(var(--px-32), 5vw, var(--px-64));
        box-sizing: border-box;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.72)),
            radial-gradient(circle at top left, rgba(0, 0, 0, 0.06), transparent 42%);
    }

    .info-section {
        display: flex;
        flex-direction: column;
        gap: var(--px-16);
        flex-shrink: 0;
    }

    .info-section + .info-section {
        padding-top: clamp(var(--px-8), 1vw, var(--px-16));
    }

    .info-text {
        margin: 0;
        max-width: 34rem;
        color: rgba(0, 0, 0, 0.72);
        font-size: clamp(1rem, 1.2vw, 1.125rem);
        line-height: 1.7;
        overflow-wrap: anywhere;
    }

    .info-title {
        margin-bottom: 0;
        max-width: 34rem;
        color: var(--color-black, #000);
        line-height: 1.18;
        letter-spacing: normal;
        text-wrap: balance;
    }

    .info-section:first-child .info-title {
        font-size: clamp(1.875rem, 3.4vw, 3.75rem);
    }

    @media screen and (max-width: 64rem) {
        .swiper-slide {
            grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
            gap: var(--px-32);
        }

        .project-info {
            padding: var(--px-32) var(--px-24);
        }
    }

    @media screen and (max-width: 55rem) {
        /* Libera el height fijo del swiper para que autoHeight funcione */
        :global(#hero.portfolio .portfolio-swiper) {
            height: auto;
            min-height: 0;
        }

        :global(#hero.portfolio .portfolio-swiper .swiper-wrapper),
        :global(#hero.portfolio .portfolio-swiper .swiper-slide) {
            height: auto;
        }

        /* En móvil: columna única, imagen arriba con proporción fija, texto debajo */
        .swiper-slide {
            grid-template-columns: 1fr;
            grid-template-rows: auto auto;
            gap: 0;
            height: auto;
        }

        .project-image {
            width: 100%;
        }

        /* Texto debajo: tarjeta legible con fondo */
        .project-info {
            display: flex;
            justify-content: flex-start;
            padding: var(--px-28) var(--px-20) var(--px-32);
            gap: var(--px-24);
            overflow-y: visible;
            background-color: var(--color-bg, #fff);
        }
    }
</style>

<script>
    import { initSwiper } from "@utils/initSwiper";

    function initPortfolioSlider() {
        const portfolioSwiper = initSwiper("portfolio", {
            autoHeight: true,
            spaceBetween: 30,
            autoplay: false,
            pagination: {
                el: ".portfolio-pagination",
                clickable: true,
            },
        });

        return () => {
            portfolioSwiper.destroy();
        };
    }

    let cleanup = initPortfolioSlider();

    document.addEventListener("astro:after-swap", () => {
        if (cleanup) cleanup();
        cleanup = initPortfolioSlider();
    });
</script>

---
import BaseSwiper from "./BaseSwiper.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import after1Image from "/src/assets/images/after1.png";
import after2Image from "/src/assets/images/after2.png";
import { getPortfolioProjects } from "@lib/wordpress";

interface Props {
    /** Oculta la etiqueta PORTFOLIO y el título (p. ej. cuando va encima del hero). */
    hideSectionHeading?: boolean;
}

const { hideSectionHeading = false } = Astro.props;

type ProjectImage = {
    src: ImageMetadata | string;
    alt: string;
};

type Project = {
    id: number;
    images: {
        after: ProjectImage;
    };
    info: {
        challenge: { title: string; text: string };
        result: { title: string; text: string };
    };
};

const catalogGlob = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/images/catalog/*.{jpeg,jpg}",
    { eager: true },
);

function fileNameFromPath(path: string): string {
    const parts = path.split("/");
    return parts[parts.length - 1] ?? path;
}

function catalogPathSortKey(path: string): number {
    const name = fileNameFromPath(path);
    const match = name.match(/(\d+)/);
    return match ? parseInt(match[1], 10) : 9999;
}

const catalogEntries = Object.entries(catalogGlob).sort(
    ([pathA], [pathB]) =>
        catalogPathSortKey(pathA) - catalogPathSortKey(pathB) ||
        pathA.localeCompare(pathB),
);

const catalogProjects: Project[] = catalogEntries.map(
    ([path, mod], index) => ({
        id: index + 1,
        images: {
            after: {
                src: mod.default,
                alt: `Producto del catálogo AGL — ${fileNameFromPath(path)}`,
            },
        },
        info: {
            challenge: {
                title: "Producto",
                text: "Consulte disponibilidad, medidas y acabados con nuestro equipo de ventas.",
            },
            result: {
                title: "Catálogo",
                text: "Referencia de nuestro catálogo. Deslice para ver más productos.",
            },
        },
    }),
);

const fallbackProjects: Project[] = [
    {
        id: 1,
        images: {
            after: {
                src: after1Image,
                alt: "A modern, open-concept living space with a wooden table, chairs, and a metal staircase. The room is lit by ceiling lights and natural sunlight from large windows.",
            },
        },
        info: {
            challenge: {
                title: "Client's Challenge",
                text: "We wanted to transform our unfinished space into a modern, functional home with an open-concept design that maximizes space, brings in plenty of natural light, and fits seamlessly into our daily lives.",
            },
            result: {
                title: "Result",
                text: "Our home now feels more open and airy. The transformation has expanded our living area, making every room feel larger and brighter. With a design that prioritizes natural light, our home is now perfectly set up for everyday living and family moments.",
            },
        },
    },
    {
        id: 2,
        images: {
            after: {
                src: after2Image,
                alt: "A modern kitchen with dark wood cabinets, stainless steel appliances, and a stone backsplash.",
            },
        },
        info: {
            challenge: {
                title: "Client's Challenge",
                text: "Our kitchen felt outdated. The all-white design was plain, and the layout wasn't as functional as it could be. We wanted a space with better lighting that made cooking more enjoyable.",
            },
            result: {
                title: "Result",
                text: "Now, our kitchen feels completely renewed. The improved lighting makes the space brighter and more welcoming, while the new wood-style elements fit perfectly with our vision.",
            },
        },
    },
];

const staticProjects: Project[] =
    catalogProjects.length > 0 ? catalogProjects : fallbackProjects;

const wpProjects = await getPortfolioProjects();

const projects: Project[] = wpProjects
    ? wpProjects.map((p) => ({
          id: p.id,
          images: {
              after: {
                  src: p.acf.after_image ? p.acf.after_image.url : "",
                  alt: p.acf.after_image ? p.acf.after_image.alt : "",
              },
          },
          info: {
              challenge: {
                  title: p.acf.challenge_title || "Client's Challenge",
                  text: p.acf.challenge_text,
              },
              result: {
                  title: p.acf.result_title || "Result",
                  text: p.acf.result_text,
              },
          },
      }))
    : staticProjects;
---

<section id="portfolio" class="portfolio">
    <div class="section-container">
        {
            !hideSectionHeading && (
                <>
                    <span class="section-tag">PORTFOLIO</span>
                    <h2 class="section-title">See the transformation.</h2>
                </>
            )
        }
        <BaseSwiper sliderName="portfolio" navigation={false}>
            {
                projects.map((project, index) => (
                    <div class="swiper-slide">
                        <div class="project-image">
                            {typeof project.images.after.src === "string" ? (
                                <img
                                    class="image"
                                    src={project.images.after.src}
                                    alt={project.images.after.alt}
                                    width="1144"
                                    height="800"
                                    loading={index === 0 ? "eager" : "lazy"}
                                    decoding="async"
                                />
                            ) : (
                                <Image
                                    class="image"
                                    src={project.images.after.src}
                                    alt={project.images.after.alt}
                                    width={1144}
                                    height={800}
                                    loading={index === 0 ? "eager" : "lazy"}
                                    decoding="async"
                                />
                            )}
                        </div>
                        <div class="project-info">
                            <div class="info-section">
                                <h3 class="section-subtitle info-title">
                                    {project.info.challenge.title}
                                </h3>
                                <p class="info-text">
                                    {project.info.challenge.text}
                                </p>
                            </div>
                            <div class="info-section">
                                <h3 class="section-subtitle info-title">
                                    {project.info.result.title}
                                </h3>
                                <p class="info-text">
                                    {project.info.result.text}
                                </p>
                            </div>
                        </div>
                    </div>
                ))
            }
        </BaseSwiper>
    </div>
</section>

<style>
    /* Sin flechas: sin padding lateral extra en el swiper */
    :global(.portfolio-swiper) {
        padding-inline: 0;
        position: relative;
    }

    .swiper-slide {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(var(--px-32), 4vw, var(--px-64));
        opacity: 0;
        transform: scale(0.75);
        transition: all var(--transition-long);
    }

    .swiper-slide-active {
        opacity: 1;
        transform: scale(1);
    }

    .swiper-slide-prev,
    .swiper-slide-next {
        opacity: 0;
        transform: scale(0.75);
    }

    .project-image {
        position: relative;
        min-height: 25rem;
        overflow: hidden;
    }

    .image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .project-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: var(--px-32);
    }

    .info-section {
        display: flex;
        flex-direction: column;
        gap: var(--px-16);
    }

    .info-title {
        margin-bottom: 0;
    }

    .view-details {
        display: inline-flex;
        font-weight: 500;
        margin-top: auto;
    }

    .btn--secondary {
        border-bottom: var(--px-2) solid currentColor;
    }

    .btn--secondary-hovered {
        display: block;
    }

    @media screen and (max-width: 64rem) {
        .swiper-slide {
            gap: var(--px-32);
        }
    }

    @media screen and (max-width: 55rem) {
        .swiper-slide {
            grid-template-columns: 1fr;
            gap: var(--px-32);
        }
    }
</style>

<script>
    import { initSwiper } from "@utils/initSwiper";

    function initPortfolioSlider() {
        const portfolioSwiper = initSwiper("portfolio", {
            spaceBetween: 30,
            autoplay: {
                delay: 5000,
                disableOnInteraction: false,
            },
            pagination: {
                el: ".portfolio-pagination",
                clickable: true,
            },
        });

        return () => {
            portfolioSwiper.destroy();
        };
    }

    let cleanup = initPortfolioSlider();

    document.addEventListener("astro:after-swap", () => {
        if (cleanup) cleanup();
        cleanup = initPortfolioSlider();
    });
</script>

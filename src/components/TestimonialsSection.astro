---
const segments = [
    {
        title: "Automotriz",
        text: "Aceites Quartz y ELF Evolution para talleres, refaccionarias y servicio preventivo.",
        href: "/products",
    },
    {
        title: "Motocicletas",
        text: "Lubricantes ELF Moto para motores 2T y 4T, con protección en ciudad y carretera.",
        href: "/products",
    },
    {
        title: "Transporte",
        text: "Rubia y soluciones para servicio pesado, flotillas, autobuses y motores diesel.",
        href: "/products",
    },
    {
        title: "Industria",
        text: "Hidráulicos, engranajes, grasas y fluidos especiales para operación continua.",
        href: "/products",
    },
];
---

<section id="segments" class="segments" aria-labelledby="segments-heading">
    <div class="section-container">
        <div class="segments-header">
            <span class="section-tag">Líneas de producto</span>
            <h2 id="segments-heading" class="section-title">
                Lubricantes para cada necesidad de consumo y operación.
            </h2>
            <p class="segments-lead">
                Al estilo de TotalEnergies, agrupamos la oferta por aplicación para
                que el cliente encuentre rápido la solución correcta.
            </p>
        </div>

        <div class="segments-grid">
            {
                segments.map((segment) => (
                    <article class="segment-card">
                        <span class="segment-card__mark" aria-hidden="true" />
                        <h3 class="segment-card__title">{segment.title}</h3>
                        <p class="segment-card__text">{segment.text}</p>
                        <a href={segment.href} class="segment-card__link">
                            Ver productos
                        </a>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    .segments {
        background: var(--color-white);
    }

    .segments-header {
        max-width: 54rem;
    }

    .segments-lead {
        max-width: 46rem;
        margin-top: calc(var(--px-48) * -1);
        margin-bottom: var(--px-48);
        color: var(--color-text-secondary);
        font-size: var(--text-xl);
    }

    .segments-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: var(--px-20);
    }

    .segment-card {
        position: relative;
        min-height: 18rem;
        padding: var(--px-32);
        border-radius: var(--px-16);
        background: var(--color-white);
        border: 1px solid var(--color-border);
        border-top: 4px solid var(--color-brand-blue);
        box-shadow: none;
        overflow: hidden;
        transition:
            transform var(--transition-medium),
            border-color var(--transition-medium);
    }

    .segment-card__mark {
        display: block;
        width: var(--px-40);
        height: var(--px-4);
        margin-bottom: var(--px-40);
        border-radius: 999px;
        background: var(--color-brand-red);
    }

    .segment-card__title {
        margin: 0 0 var(--px-16);
        color: var(--color-brand-navy);
        font-size: var(--text-2xl);
        font-weight: 800;
        line-height: 1.15;
    }

    .segment-card__text {
        margin: 0 0 var(--px-28);
        color: var(--color-text-secondary);
    }

    .segment-card__link {
        position: relative;
        z-index: 1;
        color: var(--color-brand-blue);
        font-size: var(--text-xs);
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    @media (hover: hover) and (pointer: fine) {
        .segment-card:hover {
            transform: translateY(-4px);
            border-color: var(--color-brand-blue);
        }
    }

    @media screen and (max-width: 64rem) {
        .segments-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media screen and (max-width: 42.188rem) {
        .segments-lead {
            margin-top: 0;
            font-size: var(--text-base);
        }

        .segments-grid {
            grid-template-columns: 1fr;
        }

        .segment-card {
            min-height: auto;
        }
    }
</style>

---
import { Image } from 'astro:assets';
import { TEAM_MEMBERS } from '@lib/team';
---

<section
  id="equipo"
  class="about-team"
  aria-labelledby="about-team-heading"
>
  <div class="section-container about-team__container">
    <header class="about-team__header">
      <h2 id="about-team-heading" class="section-title about-team__title">
        Nuestro equipo
      </h2>
    </header>

    <ul class="about-team__grid">
      {
        TEAM_MEMBERS.map((member) => (
          <li class="about-team__item">
            <figure class="about-team__card">
              <Image
                src={member.image}
                alt={member.role}
                class="about-team__photo"
                width={480}
                height={480}
                loading="lazy"
                decoding="async"
              />
              <figcaption class="about-team__caption">
                <span class="about-team__role">{member.role}</span>
              </figcaption>
            </figure>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .about-team {
    padding-top: var(--px-80);
    padding-bottom: var(--px-80);
    background: var(--color-white);
  }

  .about-team__container {
    max-width: 56rem;
    margin-inline: auto;
  }

  .about-team__header {
    text-align: center;
    margin-bottom: var(--px-48);
  }

  .about-team__title {
    margin-bottom: var(--px-48);
  }

  .about-team__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
  }

  .about-team__item {
    aspect-ratio: 1;
    min-width: 0;
  }

  .about-team__card {
    position: relative;
    margin: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #e8eaee;
  }

  .about-team__photo {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(100%);
    transition: filter 0.35s ease;
  }

  .about-team__caption {
    position: absolute;
    inset: auto 0 0;
    padding: var(--px-20) var(--px-12);
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 0, 0, 0.72) 100%
    );
    color: var(--color-white);
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .about-team__role {
    display: block;
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.02em;
    opacity: 0.95;
  }

  @media (hover: hover) and (pointer: fine) {
    .about-team__card:hover .about-team__photo {
      filter: grayscale(0%);
    }

    .about-team__card:hover .about-team__caption {
      opacity: 1;
    }
  }

  @media screen and (max-width: 48rem) {
    .about-team {
      padding-top: var(--px-64);
      padding-bottom: var(--px-64);
    }

    .about-team__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .about-team__caption {
      opacity: 1;
    }

    .about-team__photo {
      filter: grayscale(100%);
    }
  }

  @media screen and (max-width: 28rem) {
    .about-team__grid {
      grid-template-columns: 1fr;
      max-width: 20rem;
      margin-inline: auto;
    }
  }
</style>

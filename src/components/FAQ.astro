---
const faqItems = [
    {
        id: 1,
        question: "¿Qué marcas distribuye AGL Legaspi?",
        answer:
            "Distribuimos productos TotalEnergies y ELF para aplicaciones automotrices, motocicletas, transporte, industria, transmisión y grasas.",
    },
    {
        id: 2,
        question: "¿Me pueden ayudar a elegir el aceite correcto?",
        answer:
            "Sí. Revisamos el tipo de motor, equipo, aplicación y condiciones de trabajo para recomendar viscosidad, tecnología y presentación adecuada.",
    },
    {
        id: 3,
        question: "¿En qué zonas tienen cobertura?",
        answer:
            "Atendemos principalmente Ciudad de México, Estado de México, Morelos, Oaxaca y zonas cercanas desde nuestros centros de distribución.",
    },
    {
        id: 4,
        question: "¿Venden para talleres, flotillas e industria?",
        answer:
            "Sí. El portafolio está pensado para consumo profesional: talleres, refaccionarias, flotillas, servicio pesado, maquinaria e industria.",
    },
];
---

<section id="faq" class="faq" aria-labelledby="faq-heading">
  <div class="section-container faq-container">
    <div class="faq-header">
      <span class="section-tag">Preguntas frecuentes</span>
      <h2 id="faq-heading" class="section-title">Resolvemos la compra técnica.</h2>
      <p class="faq-lead">
        La experiencia debe sentirse clara y confiable, como la referencia:
        menos fricción, más orientación.
      </p>
    </div>

    <div class="faq-content">
      <div class="accordion">
        {
          faqItems.map(item => (
            <div class="accordion-item">
              <button class="accordion-button" aria-expanded="false">
                <span class="button-text">{item.question}</span>
                <svg
                  class="button-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M12 5v14M5 12h14" />
                </svg>
              </button>
              <div class="accordion-content" aria-hidden="true">
                <div class="content-wrapper">
                  <p>{item.answer}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .faq {
    background: var(--color-background);
  }

  .faq-container {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: var(--px-64);
    align-items: start;
  }

  .faq-header {
    position: sticky;
    top: calc(var(--h-menu-bar) + var(--px-24));
    max-width: 32rem;
  }

  .faq-lead {
    margin-top: calc(var(--px-48) * -1);
    color: var(--color-text-secondary);
    font-size: var(--text-xl);
  }

  .accordion {
    display: flex;
    flex-direction: column;
    border-radius: var(--px-20);
    background: var(--color-white);
    box-shadow: none;
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .accordion-item {
    border-bottom: 1px solid var(--color-border);
  }

  .accordion-item:last-child {
    border-bottom: 0;
  }

  .accordion-button {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--px-16);
    padding: var(--px-24);
    background: none;
    border: none;
    color: var(--color-brand-navy);
    cursor: pointer;
    text-align: left;
    transition: all var(--transition-long);
  }

  .button-text {
    font-size: var(--text-xl);
    font-weight: 700;
    transition: all var(--transition-long);
  }

  .button-icon {
    width: var(--px-20);
    height: var(--px-20);
    color: var(--color-brand-red);
    transition: all var(--transition-long);
    flex-shrink: 0;
  }

  .accordion-item.active .button-icon {
    transform: rotate(45deg);
  }

  .accordion-content {
    height: 0;
    overflow: hidden;
    transition: height var(--transition-long);
  }

  .content-wrapper {
    padding: 0 var(--px-24) var(--px-24);
    opacity: 0;
    transform: translateY(10px);
    transition: all var(--transition-long);
  }

  .accordion-item.active .content-wrapper {
    opacity: 1;
    transform: translateY(0);
  }

  @media (hover: hover) and (pointer: fine) {
    .accordion-button:hover {
      color: var(--color-brand-blue);
    }
  }

  @media (max-width: 64rem) {
    .faq-container {
      grid-template-columns: 1fr;
      gap: var(--px-32);
    }

    .faq-header {
      position: static;
      max-width: none;
    }

    .faq-lead {
      margin-top: 0;
    }
  }
</style>

<script>
  function initFAQAccordion() {
    const accordionContainer = document.querySelector('.faq-container');

    if (!accordionContainer) return;

    accordionContainer.addEventListener('click', e => {
      const button = (e.target as HTMLElement).closest('.accordion-button');

      if (!button) return;

      const item = button.closest('.accordion-item');
      const content = item?.querySelector<HTMLElement>('.accordion-content');

      if (!item || !content) return;

      const isActive = item.classList.contains('active');

      document.querySelectorAll('.accordion-item.active').forEach(accItem => {
        const accContent =
          accItem.querySelector<HTMLElement>('.accordion-content');
        const accButton = accItem.querySelector('.accordion-button');

        if (!accContent || !accButton) return;

        if (accItem !== item) {
          accItem.classList.remove('active');
          accContent.style.height = '0';
          accButton.setAttribute('aria-expanded', 'false');
          accContent.setAttribute('aria-hidden', 'true');
        }
      });

      if (!isActive) {
        item.classList.add('active');
        content.style.height = content.scrollHeight + 'px';
        button.setAttribute('aria-expanded', 'true');
        content.setAttribute('aria-hidden', 'false');
      } else {
        item.classList.remove('active');
        content.style.height = '0';
        button.setAttribute('aria-expanded', 'false');
        content.setAttribute('aria-hidden', 'true');
      }
    });
  }

  initFAQAccordion();
  document.addEventListener('astro:after-swap', initFAQAccordion);
</script>

---
import { CONTACT_LOCATIONS, toTelHref } from '@consts';

type Props = {
  pageLayout?: boolean;
};

const { pageLayout = false } = Astro.props;
---

<section
  id="contact"
  class:list={['contact', { 'contact--page': pageLayout }]}
  aria-label="Contacto"
>
  <div class="section-container contact-container">
    <header class="contact-header">
      <span class="section-tag">CONTACTO</span>
      <h2 class="section-title contact-heading">
        Solicita nuestro catálogo de aceites y lubricantes
      </h2>
    </header>

    <div class="contact-split">
      <div class="contact-split__form">
        <form class="contact-form" action="">
          <div class="contact-form-fields">
          <div class="form-group">
            <label class="form-label" for="contact-name">Nombre</label>
            <input
              class="form-input"
              id="contact-name"
              name="name"
              type="text"
              placeholder="Su nombre"
              required
            />
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-email-field">Correo electrónico</label>
            <input
              class="form-input"
              id="contact-email-field"
              name="email"
              type="email"
              placeholder="correo@ejemplo.com"
              required
            />
          </div>
          <div class="form-group message-group">
            <label class="form-label" for="contact-message">Mensaje</label>
            <textarea
              class="form-input form-textarea"
              id="contact-message"
              name="message"
              placeholder="Cuéntenos qué producto o servicio necesita"
              rows="4"
              required></textarea>
          </div>
          </div>
          <div class="form-submit">
          <button type="submit" class="btn btn--primary">Enviar mensaje</button>
          <div class="contact-terms">
            <span class="contact-terms-icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                ><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"
                ></path><path d="M12 8h.01"></path></svg
              >
            </span>
            Todos los campos son obligatorios. Al enviar el formulario acepta los
            <a class="text-link" href="/legal/terms">términos y condiciones</a>
            y el
            <a class="text-link" href="/legal/privacy">aviso de privacidad</a>.
          </div>
          </div>
          <div id="form-feedback" class="form-feedback" hidden>
            <p>¡Gracias! Su mensaje ha sido enviado.</p>
          </div>
        </form>
      </div>

      <aside class="contact-split__channels" aria-label="Teléfonos de contacto">
        <h3 class="contact-channels-title">Hable con nuestro equipo</h3>
        <address class="contact-channels-address">
          <div class="contact-channels-grid">
            {
              CONTACT_LOCATIONS.map(loc => (
                <div class="contact-channel">
                  <p class="contact-channel__label">{loc.title}</p>
                  <ul class="contact-channel__phones">
                    {loc.phones.map(phone => (
                      <li>
                        <a href={toTelHref(phone)} class="contact-detail contact-phone">
                          {phone}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
        </address>
      </aside>
    </div>

    <section
      class="contact-branches"
      aria-labelledby="contact-branches-heading"
    >
      <p class="section-tag contact-branches-tag" id="contact-branches-heading">
        SUCURSALES
      </p>
      <ul class="contact-branches__list">
        {
          CONTACT_LOCATIONS.map(loc => (
            <li class="contact-branch">
              <h4 class="contact-branch__title">{loc.title}</h4>
              <p class="contact-branch__address">{loc.address}</p>
              <div class="contact-branch__map">
                <iframe
                  src={loc.embedSrc}
                  title={`Mapa: ${loc.title}`}
                  width="600"
                  height="360"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                />
              </div>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</section>

<style>
  .contact {
    display: grid;
    background: var(--color-white);
  }

  .contact--page {
    padding-top: calc(var(--h-menu-bar) + var(--px-64));
  }

  .section-container.contact-container {
    display: grid;
    gap: var(--px-48);
  }

  .contact-header {
    max-width: 44rem;
  }

  .contact-header .section-tag {
    margin-bottom: var(--px-16);
  }

  .contact-heading {
    margin-bottom: 0;
  }

  .contact-split {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    gap: var(--px-40) var(--px-56);
    align-items: start;
  }

  .contact-split__form,
  .contact-split__channels {
    min-width: 0;
  }

  .contact-channels-title {
    font-size: var(--text-xl);
    font-weight: 500;
    margin: 0 0 var(--px-16);
    line-height: 1.3;
  }

  .contact-channels-address {
    font-style: normal;
    margin: 0;
  }

  .contact-channels-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--px-20) var(--px-28);
    margin-top: var(--px-16);
  }

  .contact-channel__label {
    margin: 0 0 var(--px-8);
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1.35;
  }

  .contact-channel__phones {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--px-4);
  }

  .contact-channel__phones .contact-detail {
    display: inline-block;
  }

  .contact-branches {
    padding: var(--px-48) 0 0;
    border-top: 1px solid var(--color-border);
  }

  .contact-branches-tag {
    margin-bottom: var(--px-28);
  }

  .contact-branches__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--px-36) var(--px-48);
    align-items: start;
  }

  .contact-branch {
    display: flex;
    flex-direction: column;
    gap: var(--px-12);
    min-width: 0;
  }

  .contact-branch__title {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .contact-branch__address {
    margin: 0;
    font-size: var(--text-base);
    line-height: 1.6;
    opacity: 0.8;
  }

  .contact-branch__map {
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: var(--px-16);
  }

  .contact-branch__map iframe {
    display: block;
    width: 100%;
    height: 14rem;
    min-height: 14rem;
  }

  .contact-form-fields {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--px-24);
    margin-bottom: var(--px-40);
  }

  .form-group {
    display: grid;
    gap: var(--px-8);
  }

  .form-label {
    font-size: var(--px-18);
    font-weight: 500;
  }

  .form-input {
    color: var(--color-text-primary);
    padding: var(--px-16) var(--px-20);
    box-shadow: none;
    border: 1px solid var(--color-border);
    border-radius: var(--px-12);
    transition: all var(--transition-short);
    font-size: var(--text-sm);
  }

  .form-input:focus {
    color: var(--color-primary);
    border-color: var(--color-border-focus);
    box-shadow: 0 0 0 3px rgba(0, 193, 206, 0.16);
    outline: none;
  }

  .form-group.message-group {
    grid-column: 1 / -1;
  }

  .form-submit {
    display: flex;
    gap: var(--px-16);
    align-items: center;
    justify-content: space-between;
  }

  .form-feedback {
    margin-top: var(--px-24);
    color: #006600;
    font-weight: 500;
    animation: var(--transition-long);
  }

  .contact-terms {
    font-size: var(--text-xs);
    max-width: 18.75rem;
  }

  .contact-terms-icon svg {
    display: inline;
    width: var(--text-base);
    margin-bottom: var(--px-2);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .contact-detail {
    opacity: 0.8;
    font-size: var(--text-sm);
    transition: opacity var(--transition-short);
  }

  .contact-detail:active {
    opacity: 1;
  }

  @media (hover: hover) and (pointer: fine) {
    .contact-detail:hover {
      opacity: 1;
    }

    .form-input:hover {
      border-color: var(--color-border-hover);
    }
  }

  @media (max-width: 66.5rem) {
    .contact-split {
      grid-template-columns: 1fr;
      gap: var(--px-40);
    }

    .contact-form-fields {
      grid-template-columns: 1fr;
    }

    .form-submit {
      flex-direction: column;
      align-items: start;
    }
  }

  @media (max-width: 40rem) {
    .contact-channels-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 56rem) {
    .contact-branches__list {
      grid-template-columns: 1fr;
      gap: var(--px-32);
    }

    .contact-branch__map iframe {
      height: 13rem;
      min-height: 13rem;
    }
  }

  @media (max-width: 48rem) {
    .section-container.contact-container {
      gap: var(--px-40);
    }

    .contact-branches {
      padding-top: var(--px-36);
    }
  }

  @media screen and (max-width: 48rem) {
    .contact--page {
      padding-top: calc(var(--h-menu-bar) + var(--px-48));
    }
  }
</style>

<script>
  import { onPageReady } from '@utils/onPageReady';

  onPageReady(() => {
    const form = document.querySelector<HTMLFormElement>('.contact-form');
    if (!form) return;

    const onSubmit = async (e: Event) => {
      e.preventDefault();

      const feedback = document.getElementById('form-feedback');
      const submitButton = form.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement | null;

      if (!feedback || !submitButton) return;

      submitButton.disabled = true;
      const originalText = submitButton.textContent;
      submitButton.textContent = 'Enviando…';

      await new Promise((resolve) => setTimeout(resolve, 1500));

      feedback.hidden = false;

      form.reset();
      submitButton.textContent = originalText;
      submitButton.disabled = false;

      setTimeout(() => {
        feedback.hidden = true;
      }, 4000);
    };

    form.addEventListener('submit', onSubmit);
    return () => form.removeEventListener('submit', onSubmit);
  }, { root: '.contact-form' });
</script>

---
import {
  CONTACT_LOCATIONS,
  CONTACT_OFFICE_HOURS,
  SITE,
  toTelHref,
} from '@consts';

type Props = {
  pageLayout?: boolean;
};

const { pageLayout = false } = Astro.props;
---

<section
  id="contact"
  class:list={['contact', { 'contact--page': pageLayout }]}
  aria-label="Contacto"
>
  <div class="section-container contact-container">
    <div class="contact-layout">
      <aside class="contact-info" aria-label="Datos de contacto">
        <div class="contact-info__shared">
          <article class="contact-info-card">
            <span class="contact-info-card__icon" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </span>
            <h3 class="contact-info-card__title">Correo</h3>
            <p class="contact-info-card__text">
              <a href={`mailto:${SITE.EMAIL}`} class="contact-info-card__link">
                {SITE.EMAIL}
              </a>
            </p>
          </article>

          <article class="contact-info-card">
            <span class="contact-info-card__icon" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </span>
            <h3 class="contact-info-card__title">Horario</h3>
            <p class="contact-info-card__text">{CONTACT_OFFICE_HOURS}</p>
          </article>
        </div>

        {
          CONTACT_LOCATIONS.map((loc) => (
            <div class="contact-location">
              <h2 class="contact-location__title">{loc.title}</h2>
              <div class="contact-info__grid">
                <article class="contact-info-card">
                  <span class="contact-info-card__icon" aria-hidden="true">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                      ></path>
                      <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                  </span>
                  <h3 class="contact-info-card__title">Dirección</h3>
                  <p class="contact-info-card__text">
                    <a
                      href={loc.mapsUrl}
                      class="contact-info-card__link"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {loc.address}
                    </a>
                  </p>
                </article>

                <article class="contact-info-card">
                  <span class="contact-info-card__icon" aria-hidden="true">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path
                        d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                      ></path>
                    </svg>
                  </span>
                  <h3 class="contact-info-card__title">Teléfono</h3>
                  <p class="contact-info-card__text">
                    <a
                      href={toTelHref(loc.phone)}
                      class="contact-info-card__link"
                    >
                      {loc.phone}
                    </a>
                  </p>
                </article>
              </div>
            </div>
          ))
        }
      </aside>

      <div class="contact-form-panel">
        <header class="contact-form-panel__header">
          <p class="contact-form-panel__kicker">Contacto</p>
          <h1 class="contact-form-panel__title">
            Hable con nuestro equipo especializado
          </h1>
        </header>

        <form class="contact-form" action="">
          <div class="contact-form__row">
            <div class="form-group">
              <label class="form-label" for="contact-name">Nombre</label>
              <input
                class="form-input"
                id="contact-name"
                name="name"
                type="text"
                placeholder="Su nombre"
                required
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-email-field"
                >Correo electrónico</label
              >
              <input
                class="form-input"
                id="contact-email-field"
                name="email"
                type="email"
                placeholder="correo@ejemplo.com"
                required
              />
            </div>
          </div>

          <div class="contact-form__row">
            <div class="form-group">
              <label class="form-label" for="contact-phone">Teléfono</label>
              <input
                class="form-input"
                id="contact-phone"
                name="phone"
                type="tel"
                placeholder="(55) 0000 0000"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-subject">Asunto</label>
              <input
                class="form-input"
                id="contact-subject"
                name="subject"
                type="text"
                placeholder="Ej. cotización, asesoría técnica"
              />
            </div>
          </div>

          <div class="form-group form-group--full">
            <label class="form-label" for="contact-message">Mensaje</label>
            <textarea
              class="form-input form-textarea"
              id="contact-message"
              name="message"
              placeholder="Cuéntenos qué producto o servicio necesita"
              rows="5"
              required></textarea>
          </div>

          <div class="contact-form__footer">
            <button type="submit" class="btn btn--primary contact-form__submit">
              Enviar mensaje
            </button>
            <p class="contact-terms">
              Al enviar acepta los
              <a class="text-link" href="/legal/terms">términos</a>
              y el
              <a class="text-link" href="/legal/privacy">aviso de privacidad</a
              >.
            </p>
          </div>

          <div id="form-feedback" class="form-feedback" hidden>
            <p>¡Gracias! Su mensaje ha sido enviado.</p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--color-background);
  }

  .contact--page {
    padding-top: calc(var(--h-menu-bar) + var(--px-64));
    padding-bottom: var(--px-96);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: var(--px-40) var(--px-48);
    align-items: start;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--px-32);
    min-width: 0;
  }

  .contact-info__shared,
  .contact-info__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--px-20);
  }

  .contact-location__title {
    margin: 0 0 var(--px-16);
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .contact-info-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--px-12);
    padding: var(--px-28) var(--px-20);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--px-12);
    box-shadow: 0 8px 24px rgba(16, 38, 79, 0.06);
  }

  .contact-info-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    color: var(--color-brand-blue);
  }

  .contact-info-card__icon svg {
    width: 1.75rem;
    height: 1.75rem;
  }

  .contact-info-card__title {
    margin: 0;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .contact-info-card__text {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-text-secondary);
    opacity: 1;
  }

  .contact-info-card__link {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-short);
  }

  .contact-form-panel {
    padding: var(--px-40) var(--px-40) var(--px-48);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--px-16);
    box-shadow: 0 12px 40px rgba(16, 38, 79, 0.08);
    min-width: 0;
  }

  .contact-form-panel__header {
    margin-bottom: var(--px-32);
  }

  .contact-form-panel__kicker {
    margin: 0 0 var(--px-8);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-brand-blue);
    letter-spacing: 0.04em;
  }

  .contact-form-panel__title {
    margin: 0;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--px-24);
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--px-24);
  }

  .form-group {
    display: grid;
    gap: var(--px-8);
  }

  .form-group--full {
    grid-column: 1 / -1;
  }

  .form-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .form-input {
    color: var(--color-text-primary);
    padding: var(--px-14) var(--px-16);
    border: 1px solid var(--color-border);
    border-radius: var(--px-8);
    font-size: var(--text-sm);
    background: var(--color-white);
    transition:
      border-color var(--transition-short),
      box-shadow var(--transition-short);
  }

  .form-textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .form-input::placeholder {
    color: var(--color-text-secondary);
    opacity: 0.7;
  }

  .form-input:focus {
    border-color: var(--color-border-focus);
    box-shadow: 0 0 0 3px rgba(0, 193, 206, 0.16);
    outline: none;
  }

  .contact-form__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--px-20) var(--px-24);
    margin-top: var(--px-8);
  }

  .contact-form__submit {
    min-width: 10rem;
  }

  .contact-terms {
    margin: 0;
    flex: 1;
    min-width: 12rem;
    font-size: var(--text-xs);
    line-height: 1.5;
    color: var(--color-text-secondary);
    opacity: 1;
  }

  .form-feedback {
    margin: 0;
    color: #006600;
    font-weight: 500;
    font-size: var(--text-sm);
  }

  @media (hover: hover) and (pointer: fine) {
    .contact-info-card__link:hover {
      color: var(--color-brand-blue);
    }

    .form-input:hover {
      border-color: var(--color-border-hover);
    }
  }

  @media screen and (max-width: 64rem) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: var(--px-40);
    }
  }

  @media screen and (max-width: 42rem) {
    .contact--page {
      padding-top: calc(var(--h-menu-bar) + var(--px-48));
    }

    .contact-info__shared,
    .contact-info__grid,
    .contact-form__row {
      grid-template-columns: 1fr;
    }

    .contact-form-panel {
      padding: var(--px-28) var(--px-24) var(--px-36);
    }

    .contact-form__footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  import { onPageReady } from '@utils/onPageReady';

  onPageReady(() => {
    const form = document.querySelector<HTMLFormElement>('.contact-form');
    if (!form) return;

    const onSubmit = async (e: Event) => {
      e.preventDefault();

      const feedback = document.getElementById('form-feedback');
      const submitButton = form.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement | null;

      if (!feedback || !submitButton) return;

      submitButton.disabled = true;
      const originalText = submitButton.textContent;
      submitButton.textContent = 'Enviando…';

      await new Promise((resolve) => setTimeout(resolve, 1500));

      feedback.hidden = false;

      form.reset();
      submitButton.textContent = originalText;
      submitButton.disabled = false;

      setTimeout(() => {
        feedback.hidden = true;
      }, 4000);
    };

    form.addEventListener('submit', onSubmit);
    return () => form.removeEventListener('submit', onSubmit);
  }, { root: '.contact-form' });
</script>

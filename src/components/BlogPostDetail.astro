---
import { Image } from 'astro:assets';
import {
  formatPortfolioDate,
  PORTFOLIO_CATEGORY_LABELS,
  type PortfolioPost,
} from '@lib/portfolio';

interface Props {
  post: PortfolioPost;
}

const { post } = Astro.props;
---

<article class="blog-post">
  <div class="section-container blog-post__container">
    <a href="/portfolio" class="blog-post__back text-link">
      ← Volver al blog
    </a>

    <header class="blog-post__header">
      <div class="blog-post__meta">
        <span class="blog-post__category">
          {PORTFOLIO_CATEGORY_LABELS[post.category]}
        </span>
        <time class="blog-post__date" datetime={post.date}>
          {formatPortfolioDate(post.date)}
        </time>
      </div>
      <h1 class="blog-post__title">{post.title}</h1>
      <p class="blog-post__excerpt">{post.excerpt}</p>
    </header>

    {
      post.image && (
        <figure class="blog-post__figure">
          <Image
            src={post.image}
            alt=""
            class="blog-post__image"
            width={1200}
            height={675}
            loading="eager"
            fetchpriority="high"
          />
        </figure>
      )
    }

    <div class="blog-post__content">
      {post.body.map((paragraph) => <p>{paragraph}</p>)}
    </div>

    <footer class="blog-post__footer">
      <a href="/contact" class="btn btn--primary">Contactar a AGL Legaspi</a>
      <a href="/portfolio" class="blog-post__back-footer text-link">
        Ver más publicaciones
      </a>
    </footer>
  </div>
</article>

<style>
  .blog-post {
    padding-top: calc(var(--h-menu-bar) + var(--px-64));
    padding-bottom: var(--px-96);
    background: var(--color-white);
  }

  .blog-post__container {
    max-width: 46rem;
  }

  .blog-post__back {
    display: inline-block;
    margin-bottom: var(--px-32);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .blog-post__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--px-8) var(--px-16);
    margin-bottom: var(--px-16);
    font-size: var(--text-sm);
  }

  .blog-post__category {
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-brand-red);
  }

  .blog-post__date {
    color: var(--color-text-secondary);
  }

  .blog-post__title {
    margin: 0 0 var(--px-20);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .blog-post__excerpt {
    margin: 0;
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--color-text-dark);
    opacity: 0.9;
  }

  .blog-post__figure {
    margin: var(--px-40) 0;
    border-radius: var(--px-12);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .blog-post__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .blog-post__content {
    display: flex;
    flex-direction: column;
    gap: var(--px-20);
  }

  .blog-post__content p {
    margin: 0;
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-dark);
    opacity: 0.9;
  }

  .blog-post__footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--px-24);
    margin-top: var(--px-48);
    padding-top: var(--px-32);
    border-top: 1px solid var(--color-border);
  }

  .blog-post__back-footer {
    font-size: var(--text-sm);
    font-weight: 600;
  }

  @media screen and (max-width: 48rem) {
    .blog-post {
      padding-top: calc(var(--h-menu-bar) + var(--px-48));
    }

    .blog-post__footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

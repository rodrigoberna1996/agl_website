---
import { Image } from "astro:assets";
import productImage from "/src/assets/images/catalog/image_1.jpg";

const stats = [
    { value: "30+", label: "años de experiencia" },
    { value: "2", label: "centros de distribución" },
    { value: "4", label: "estados de cobertura" },
];
---

<section id="about" class="about" aria-labelledby="about-heading">
    <div class="section-container about-container">
        <div class="about-media">
            <Image
                src={productImage}
                alt="Productos TotalEnergies y ELF distribuidos por AGL Legaspi"
                class="about-image"
                width={900}
                height={720}
            />
        </div>

        <div class="about-content">
            <span class="section-tag">AGL Legaspi</span>
            <h2 id="about-heading" class="section-title">
                Distribución TotalEnergies y ELF con atención local.
            </h2>
            <p class="about-lead">
                Somos especialistas en aceites, grasas y fluidos lubricantes para
                sectores automotriz, transporte, industrial, agrícola y de servicio.
            </p>
            <p>
                El sitio de referencia pone al frente la tecnología y amplitud de
                TotalEnergies. Esta sección traduce esa idea al valor de AGL:
                disponibilidad regional, soporte técnico y acompañamiento antes y
                después de la compra.
            </p>

            <div class="about-stats" aria-label="Datos destacados de AGL Legaspi">
                {
                    stats.map((stat) => (
                        <div class="about-stat">
                            <strong>{stat.value}</strong>
                            <span>{stat.label}</span>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style>
    .about {
        background: var(--color-white);
    }

    .about-container {
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(0, 1fr);
        gap: var(--px-64);
        align-items: center;
    }

    .about-media {
        position: relative;
        padding: var(--px-32);
        border-radius: var(--px-16);
        background: #f3f6fa;
        border: 1px solid var(--color-border);
        overflow: hidden;
    }

    .about-media::before {
        content: "";
        position: absolute;
        top: var(--px-24);
        left: var(--px-24);
        width: var(--px-80);
        height: var(--px-6);
        border-radius: 999px;
        background: var(--color-brand-red);
    }

    .about-image {
        position: relative;
        z-index: 1;
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain;
        filter: drop-shadow(0 16px 20px rgba(16, 38, 79, 0.1));
    }

    .about-content {
        max-width: 43rem;
    }

    .about-lead {
        margin-top: calc(var(--px-48) * -1);
        color: var(--color-text-primary);
        font-size: var(--text-xl);
        font-weight: 600;
    }

    .about-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: var(--px-16);
        margin-top: var(--px-40);
    }

    .about-stat {
        padding: var(--px-20);
        border-radius: var(--px-12);
        background: var(--color-background);
        border: 1px solid var(--color-border);
    }

    .about-stat strong {
        display: block;
        color: var(--color-brand-red);
        font-size: var(--text-4xl);
        line-height: 1;
    }

    .about-stat span {
        display: block;
        margin-top: var(--px-8);
        color: var(--color-text-secondary);
        font-size: var(--text-xs);
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    @media screen and (max-width: 64rem) {
        .about-container {
            grid-template-columns: 1fr;
            gap: var(--px-40);
        }

        .about-lead {
            margin-top: 0;
        }
    }

    @media screen and (max-width: 42.188rem) {
        .about-stats {
            grid-template-columns: 1fr;
        }
    }
</style>

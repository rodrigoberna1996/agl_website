---
import { Image } from 'astro:assets';
import {
  getPortfolioPosts,
  getPortfolioPostUrl,
  getPortfolioSearchText,
  PORTFOLIO_CATEGORY_LABELS,
  formatPortfolioDate,
  type PortfolioCategory,
} from '@lib/portfolio';

const posts = getPortfolioPosts();

const filters: { key: 'all' | PortfolioCategory; label: string }[] = [
  { key: 'all', label: 'Todos' },
  ...(Object.entries(PORTFOLIO_CATEGORY_LABELS) as [PortfolioCategory, string][]).map(
    ([key, label]) => ({ key, label }),
  ),
];
---

<section class="portfolio-page" aria-labelledby="portfolio-heading">
  <div class="section-container">
    <header class="portfolio-page__header">
      <h1 id="portfolio-heading" class="section-title portfolio-page__title">
        Blog
      </h1>
    </header>

    {
      posts.length > 0 && (
        <div class="portfolio-page__toolbar">
          <div class="portfolio-page__search">
            <label class="portfolio-page__search-label" for="portfolio-search">
              Buscar
            </label>
            <div class="portfolio-page__search-field">
              <svg
                class="portfolio-page__search-icon"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.3-4.3" />
              </svg>
              <input
                type="search"
                id="portfolio-search"
                class="portfolio-page__search-input"
                placeholder="Buscar por título, tema o contenido…"
                autocomplete="off"
              />
            </div>
          </div>

          <nav
            class="portfolio-page__filters"
            aria-label="Filtrar publicaciones"
            role="group"
          >
            {filters.map((f, i) => (
              <button
                type="button"
                class:list={['portfolio-page__filter', { 'is-active': i === 0 }]}
                data-filter={f.key}
                aria-pressed={i === 0 ? 'true' : 'false'}
              >
                {f.label}
              </button>
            ))}
          </nav>
        </div>
      )
    }

    {
      posts.length === 0 ? (
        <div class="portfolio-page__empty">
          <p class="portfolio-page__empty-title">Próximamente</p>
          <p class="portfolio-page__empty-text">
            Estamos preparando publicaciones, eventos y noticias para compartir
            con usted. Vuelva pronto o{' '}
            <a href="/contact" class="text-link">
              contáctenos
            </a>{' '}
            si desea más información.
          </p>
        </div>
      ) : (
        <>
          <ul class="portfolio-page__grid" id="portfolio-grid">
            {posts.map((post) => {
              const postUrl = getPortfolioPostUrl(post.slug);
              return (
              <li
                class="portfolio-page__item"
                data-category={post.category}
                data-search={getPortfolioSearchText(post)}
              >
                <article class="portfolio-card">
                  {post.image && (
                    <a href={postUrl} class="portfolio-card__media" tabindex="-1" aria-hidden="true">
                      <Image
                        src={post.image}
                        alt=""
                        class="portfolio-card__image"
                        width={640}
                        height={400}
                        loading="lazy"
                        decoding="async"
                      />
                    </a>
                  )}
                  <div class="portfolio-card__body">
                    <div class="portfolio-card__meta">
                      <span class="portfolio-card__category">
                        {PORTFOLIO_CATEGORY_LABELS[post.category]}
                      </span>
                      <time
                        class="portfolio-card__date"
                        datetime={post.date}
                      >
                        {formatPortfolioDate(post.date)}
                      </time>
                    </div>
                    <h2 class="portfolio-card__title">
                      <a href={postUrl}>{post.title}</a>
                    </h2>
                    <p class="portfolio-card__excerpt">{post.excerpt}</p>
                    <a href={postUrl} class="portfolio-card__link text-link">
                      Leer más
                    </a>
                  </div>
                </article>
              </li>
            );
            })}
          </ul>
          <p class="portfolio-page__filter-empty" id="portfolio-filter-empty" hidden>
            No hay publicaciones en esta categoría.
          </p>
          <p class="portfolio-page__filter-empty" id="portfolio-search-empty" hidden>
            No se encontraron publicaciones para su búsqueda.
          </p>
        </>
      )
    }
  </div>
</section>

<style>
  section.portfolio-page {
    background: var(--color-white);
  }

  .portfolio-page__header {
    margin-bottom: var(--px-40);
  }

  .portfolio-page__title {
    margin-bottom: 0;
  }

  .portfolio-page__toolbar {
    display: flex;
    flex-direction: column;
    gap: var(--px-24);
    margin-bottom: var(--px-40);
  }

  .portfolio-page__search {
    max-width: 28rem;
  }

  .portfolio-page__search-label {
    display: block;
    margin-bottom: var(--px-8);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .portfolio-page__search-field {
    position: relative;
  }

  .portfolio-page__search-icon {
    position: absolute;
    left: var(--px-16);
    top: 50%;
    width: 1.125rem;
    height: 1.125rem;
    transform: translateY(-50%);
    color: var(--color-text-secondary);
    pointer-events: none;
  }

  .portfolio-page__search-input {
    width: 100%;
    padding: var(--px-14) var(--px-16) var(--px-14) calc(var(--px-16) + 1.5rem);
    border: 1px solid var(--color-border);
    border-radius: var(--px-8);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    background: var(--color-white);
    transition:
      border-color var(--transition-short),
      box-shadow var(--transition-short);
  }

  .portfolio-page__search-input::placeholder {
    color: var(--color-text-secondary);
    opacity: 0.75;
  }

  .portfolio-page__search-input:focus {
    outline: none;
    border-color: var(--color-border-focus);
    box-shadow: 0 0 0 3px rgba(0, 193, 206, 0.16);
  }

  .portfolio-page__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--px-10);
  }

  .portfolio-page__filter {
    padding: var(--px-10) var(--px-20);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-white);
    color: var(--color-text-primary);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition:
      background var(--transition-short),
      border-color var(--transition-short),
      color var(--transition-short);
  }

  .portfolio-page__filter.is-active {
    background: var(--color-brand-blue);
    border-color: var(--color-brand-blue);
    color: var(--color-white);
  }

  .portfolio-page__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--px-32);
  }

  .portfolio-card {
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--px-12);
    overflow: hidden;
    background: var(--color-white);
    transition:
      box-shadow var(--transition-medium),
      transform var(--transition-medium);
  }

  .portfolio-card:hover {
    box-shadow: 0 12px 32px rgba(16, 38, 79, 0.08);
    transform: translateY(-2px);
  }

  .portfolio-card__media {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-background);
    text-decoration: none;
  }

  .portfolio-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .portfolio-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--px-12);
    padding: var(--px-24);
  }

  .portfolio-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--px-8) var(--px-12);
    font-size: var(--text-xs);
  }

  .portfolio-card__category {
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-brand-red);
  }

  .portfolio-card__date {
    color: var(--color-text-secondary);
  }

  .portfolio-card__title {
    margin: 0;
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .portfolio-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .portfolio-card__title a:hover {
    color: var(--color-brand-blue);
  }

  .portfolio-card__excerpt {
    margin: 0;
    flex: 1;
    font-size: var(--text-base);
    line-height: 1.55;
    color: var(--color-text-dark);
    opacity: 0.85;
  }

  .portfolio-card__link {
    margin-top: auto;
    font-weight: 600;
    font-size: var(--text-sm);
  }

  .portfolio-page__empty {
    padding: var(--px-64) var(--px-48);
    text-align: center;
    border: 1px dashed var(--color-border);
    border-radius: var(--px-16);
    background: var(--color-background);
  }

  .portfolio-page__empty-title {
    margin: 0 0 var(--px-12);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .portfolio-page__empty-text {
    margin: 0 auto;
    max-width: 32rem;
    line-height: 1.6;
    opacity: 0.85;
  }

  .portfolio-page__filter-empty {
    margin: var(--px-32) 0 0;
    text-align: center;
    color: var(--color-text-secondary);
  }

  @media (hover: hover) and (pointer: fine) {
    .portfolio-page__search-input:hover {
      border-color: var(--color-border-hover);
    }
  }

  @media screen and (max-width: 64rem) {
    .portfolio-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .portfolio-page__search {
      max-width: none;
    }
  }

  @media screen and (max-width: 42rem) {
    .portfolio-page__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { onPageReady } from '@utils/onPageReady';

  function normalizeText(value: string): string {
    return value
      .toLowerCase()
      .normalize('NFD')
      .replace(/\p{M}/gu, '');
  }

  onPageReady(() => {
    const grid = document.getElementById('portfolio-grid');
    const categoryEmptyMsg = document.getElementById('portfolio-filter-empty');
    const searchEmptyMsg = document.getElementById('portfolio-search-empty');
    const searchInput = document.getElementById(
      'portfolio-search',
    ) as HTMLInputElement | null;
    const filterBtns = document.querySelectorAll<HTMLButtonElement>(
      '.portfolio-page__filter',
    );

    if (!grid) return;

    const items = grid.querySelectorAll<HTMLElement>('.portfolio-page__item');
    let activeFilter = 'all';

    const applyFilters = () => {
      const query = normalizeText(searchInput?.value.trim() ?? '');
      let visible = 0;

      items.forEach((item) => {
        const matchesCategory =
          activeFilter === 'all' || item.dataset.category === activeFilter;
        const haystack = normalizeText(item.dataset.search ?? '');
        const matchesSearch = !query || haystack.includes(query);
        const show = matchesCategory && matchesSearch;

        item.hidden = !show;
        if (show) visible += 1;
      });

      const hasSearch = query.length > 0;

      if (categoryEmptyMsg) {
        categoryEmptyMsg.hidden = visible > 0 || hasSearch;
      }

      if (searchEmptyMsg) {
        searchEmptyMsg.hidden = visible > 0 || !hasSearch;
      }
    };

    const onFilterClick = (event: Event) => {
      const btn = event.currentTarget;
      if (!(btn instanceof HTMLButtonElement)) return;

      activeFilter = btn.dataset.filter ?? 'all';

      filterBtns.forEach((filterBtn) => {
        const active = filterBtn.dataset.filter === activeFilter;
        filterBtn.classList.toggle('is-active', active);
        filterBtn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      applyFilters();
    };

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', onFilterClick);
    });

    searchInput?.addEventListener('input', applyFilters);

    applyFilters();

    return () => {
      filterBtns.forEach((btn) => {
        btn.removeEventListener('click', onFilterClick);
      });
      searchInput?.removeEventListener('input', applyFilters);
    };
  }, { root: '#portfolio-grid' });
</script>
